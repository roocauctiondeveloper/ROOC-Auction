<div class="flex space-between items-center" style="margin-bottom: 2rem;">
    <div>
        <h1 style="margin-bottom: 0.25rem;">Parties</h1>
        <p style="color: var(--text-light); margin: 0;">Manage whitelist members in parties.</p>
    </div>
</div>

<div class="grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1.5rem;">
    <% parties.forEach(party => { %>
        <div class="card" style="margin-bottom: 0;">
            <div class="flex space-between items-center" style="margin-bottom: 1rem; border-bottom: 1px solid #e2e8f0; padding-bottom: 1rem;">
                <h2 style="margin: 0; font-size: 1.25rem;"><%= party.name %></h2>
                <span class="badge <%= partyMembers[party.id].length >= 5 ? 'badge-blue' : 'badge-gray' %>">
                    <%= partyMembers[party.id].length %> / 5
                </span>
            </div>

            <!-- List of members in this party -->
            <ul style="list-style: none; padding: 0; margin: 0 0 1.5rem 0;">
                <% if (partyMembers[party.id].length === 0) { %>
                    <li style="color: var(--text-light); font-size: 0.9rem; text-align: center; padding: 1rem 0;">No members yet</li>
                <% } else { %>
                    <% partyMembers[party.id].forEach(member => { %>
                        <li class="flex space-between items-center" style="padding: 0.5rem 0; border-bottom: 1px solid #f1f5f9;">
                            <span style="font-weight: 500;"><%= member.discord_username %></span>
                            <form action="/parties/<%= party.id %>/remove/<%= member.whitelist_id %>" method="POST" style="margin: 0;">
                                <button type="submit" class="btn btn-danger" style="padding: 0.25rem 0.5rem; font-size: 0.75rem;">Remove</button>
                            </form>
                        </li>
                    <% }) %>
                <% } %>
            </ul>

            <!-- Add member form -->
            <form action="/parties/<%= party.id %>/add" method="POST" style="margin: 0; display: flex; gap: 0.5rem;">
                <select name="whitelist_id" style="flex: 1; padding: 0.5rem;" required>
                    <option value="">-- Add Member --</option>
                    <% whitelist.forEach(user => { %>
                        <option value="<%= user.id %>"><%= user.discord_username %></option>
                    <% }) %>
                </select>
                <button type="submit" class="btn btn-primary" style="padding: 0.5rem 1rem;">Add</button>
            </form>
        </div>
    <% }) %>
</div>
