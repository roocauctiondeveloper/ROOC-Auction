<style>
  /* Premium Tooltip Styling */
  .custom-tooltip {
    position: relative;
    display: inline-flex;
    align-items: center;
    cursor: help;
  }
  .custom-tooltip .tooltip-text {
    visibility: hidden;
    width: auto;
    min-width: 90px;
    white-space: nowrap;
    background-color: #0f172a;
    color: #38bdf8;
    text-align: center;
    border: 1px solid #334155;
    border-radius: 6px;
    padding: 6px 12px;
    position: absolute;
    z-index: 999;
    bottom: 130%;
    left: 50%;
    transform: translateX(-50%);
    opacity: 0;
    transition: opacity 0.15s, transform 0.15s;
    font-size: 0.8rem;
    font-weight: 700;
    line-height: 1;
    pointer-events: none;
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.4), 0 4px 6px -4px rgba(0, 0, 0, 0.4);
  }
  .custom-tooltip .tooltip-text::after {
    content: "";
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    border-width: 6px;
    border-style: solid;
    border-color: #0f172a transparent transparent transparent;
  }
  .custom-tooltip:hover .tooltip-text {
    visibility: visible;
    opacity: 1;
    transform: translateX(-50%) translateY(-2px);
  }
</style>

<div class="flex space-between items-center" style="margin-bottom: 2rem;">
  <div>
    <a href="/history" style="color: var(--text-light); text-decoration: none; font-size: 0.85rem; display: flex; align-items: center; gap: 0.4rem;">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
      Back to History
    </a>
    <h2 style="margin-top: 0.5rem; margin-bottom: 0;"><%= round.name %></h2>
    <p style="color: var(--text-light); font-size: 0.8rem; margin: 0;">Reservation Summary (Snapshot)</p>
  </div>
  <div class="badge badge-gray" style="padding: 0.4rem 0.8rem;">CLOSED</div>
</div>

<% 
  const groupedPages = {};
  reservations.forEach(item => {
    if (!groupedPages[item.page_name]) groupedPages[item.page_name] = [];
    groupedPages[item.page_name].push(item);
  });
  
  const sortedPageNames = Object.keys(groupedPages).sort((a, b) => a.length - b.length || a.localeCompare(b));
%>

<div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 1rem;">
  <% for(let pageName of sortedPageNames) { %>
    <% const items = groupedPages[pageName]; %>
    <% const reserved = items.filter(i => i.discord_user_id).length; %>
    <div class="card" style="padding: 0; overflow: hidden; margin-bottom: 0; border: 1px solid #e2e8f0; border-top: 3px solid <%= reserved === items.length ? 'var(--success)' : 'var(--primary)' %>;">
      <div style="background: #f8fafc; padding: 0.5rem 0.75rem; border-bottom: 1px solid #f1f5f9; display: flex; justify-content: space-between; align-items: center;">
        <strong style="color: var(--text); font-size: 1rem;">Page <%= pageName %></strong>
        <span style="font-size: 0.75rem; font-weight: 700; color: var(--text-light);"><%= reserved %>/<%= items.length %></span>
      </div>
      <div style="padding: 0.4rem;">
        <% for(let i of items) { %>
          <div style="padding: 0.5rem 0.6rem; border-radius: 6px; margin-bottom: 0.2rem; font-size: 0.8rem; border: 1px solid <%= i.discord_user_id ? '#dbeafe' : '#f8fafc' %>; background: <%= i.discord_user_id ? '#f0f9ff' : 'transparent' %>;">
            <div style="display: flex; justify-content: space-between; align-items: center;">
              <span style="font-weight: 600; color: <%= i.discord_user_id ? '#1e40af' : '#94a3b8' %>;">
                <%= i.item_pos %>. <%= displayItemType(i.item_type) %>
              </span>
              <% if (i.discord_user_id) { %>
                <span title="เวลาจอง" style="font-size: 0.65rem; color: #94a3b8;"><%= i.reserved_at ? formatTime(i.reserved_at) : '' %></span>
              <% } %>
            </div>
            
            <% if (i.discord_user_id) { %>
              <div style="margin-top: 2px; font-weight: 700; color: #1e3a8a; display: flex; align-items: center; gap: 4px;">
                <span style="font-size: 0.85rem;">👤</span>
                <% if (i.transferred_from_name) { %>
                  <span class="custom-tooltip" style="color: #0284c7; font-weight: 700;">
                    <%= i.discord_username %> <span style="font-size: 0.7rem; font-weight: normal; margin-left: 2px;">(🔄)</span>
                    <span class="tooltip-text"><%= i.transferred_from_name %></span>
                  </span>
                <% } else { %>
                  <%= i.discord_username %>
                <% } %>
              </div>
              <div style="font-size: 0.65rem; color: #93c5fd; font-family: monospace; margin-left: 1.1rem;">ID: <%= i.discord_user_id %></div>
            <% } else { %>
              <div style="margin-top: 2px; color: #e2e8f0; font-size: 0.75rem;">Available</div>
            <% } %>
          </div>
        <% } %>
      </div>
    </div>
  <% } %>
</div>
