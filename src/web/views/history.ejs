<div class="flex space-between items-center" style="margin-bottom: 2rem;">
  <h1>Reservation History</h1>
  <form action="/history/delete-all" method="POST" class="ajax-delete" data-confirm="ยืนยันที่จะลบประวัติทั้งหมด? การกระทำนี้ไม่สามารถย้อนกลับได้">
    <button type="submit" class="btn btn-secondary" style="color: var(--danger);">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
      ล้างประวัติทั้งหมด
    </button>
  </form>
</div>

<div class="card">
  <% if (history.length === 0) { %>
    <div style="text-align: center; padding: 4rem 1rem;">
      <div style="font-size: 3rem; margin-bottom: 1rem;">🕰️</div>
      <h3 style="color: var(--text-light);">ยังไม่มีประวัติการจอง</h3>
    </div>
  <% } else { %>
    <div class="table-responsive">
      <table>
        <thead>
          <tr>
            <th>Round Name</th>
            <th>Reservations</th>
            <th>Created At</th>
            <th style="text-align: right;">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% for(let r of history) { %>
            <tr>
              <td>
                <div style="font-weight: 700; color: var(--text);"><%= r.name %></div>
                <div style="font-size: 0.75rem; color: var(--text-light);">ID: #<%= r.id %></div>
              </td>
              <td>
                <span class="badge badge-blue"><%= r.reservation_count %> รายการ</span>
              </td>
              <td><%= new Date(r.created_at).toLocaleString('th-TH') %></td>
              <td style="text-align: right;">
                <div style="display: flex; gap: 0.5rem; justify-content: flex-end;">
                  <a href="/history/<%= r.id %>" class="btn btn-primary" style="padding: 0.4rem 0.8rem; font-size: 0.85rem;">View Details</a>
                  <form action="/history/<%= r.id %>/delete" method="POST" class="ajax-delete" data-confirm="ยืนยันที่จะลบประวัติรอบนี้?" style="display:inline;">
                    <button type="submit" class="btn btn-secondary" style="color: var(--danger); padding: 0.4rem 0.8rem; font-size: 0.85rem;">Delete</button>
                  </form>
                </div>
              </td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>
