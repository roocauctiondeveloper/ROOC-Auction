<div class="flex space-between items-center" style="margin-bottom: 2rem;">
  <h1>Reservations</h1>
  <div style="display: flex; gap: 0.5rem;">
    <div class="quota-status badge badge-green" style="font-size: 0.9rem;">
      LD Quota: <strong><%= currentRound.quota_ld >= 999 ? '∞' : currentRound.quota_ld %></strong>
    </div>
    <div class="quota-status badge badge-blue" style="font-size: 0.9rem;">
      TS Quota: <strong><%= currentRound.quota_ts >= 999 ? '∞' : currentRound.quota_ts %></strong>
    </div>
  </div>
</div>

<div class="card" style="background: linear-gradient(135deg, #eff6ff 0%, #dbeafe 100%); border: 1px solid #bfdbfe; margin-bottom: 2rem;">
    <h2 style="color: #1e40af; margin-bottom: 1rem;">⚙️ Quota Management Instructions</h2>
    <div style="color: #1e40af; font-size: 0.95rem; line-height: 1.6;">
      <p><strong>Current Policy:</strong></p>
      <ul>
        <li><strong>Feathers (LD/TS):</strong> Limited by the <strong>Quota</strong> value set in the round. If set to 1, users can reserve 1 feather piece. If 2, they can reserve 2 pieces, etc.</li>
        <li><strong>Albums/Boxes:</strong> Always limited to <strong>1 item per person</strong> (combined). These do NOT count towards the Feather quota.</li>
      </ul>
      <p style="margin-top: 1rem;">
        <em>Note: The "Smart Quota" logic handles this automatically. Whitelist members are prioritized for Album/Box slots during round opening.</em>
      </p>
    </div>
</div>

<div class="card" style="border-left: 4px solid var(--secondary); margin-bottom: 2rem;">
  <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 2rem;">
    <!-- LD -->
    <div>
      <h3 style="margin-bottom: 0.5rem;">🤍 LD Quota (White)</h3>
      <form action="/reservations/quota" method="POST" style="display: flex; gap: 0.5rem;">
        <input type="hidden" name="type" value="ld">
        <input type="number" name="quota" value="<%= currentRound.quota_ld >= 999 ? 1 : currentRound.quota_ld %>" min="1" max="999" style="width: 80px;">
        <button type="submit" class="btn btn-secondary">Set LD</button>
      </form>
      <div style="display: flex; gap: 0.5rem; margin-top: 0.5rem;">
        <form action="/reservations/quota" method="POST">
          <input type="hidden" name="type" value="ld">
          <input type="hidden" name="quota" value="999">
          <button type="submit" class="btn btn-blue" style="padding: 0.3rem 0.6rem; font-size: 0.75rem;">Unlimited</button>
        </form>
      </div>
    </div>
    <!-- TS -->
    <div>
      <h3 style="margin-bottom: 0.5rem;">❤️ TS Quota (Red)</h3>
      <form action="/reservations/quota" method="POST" style="display: flex; gap: 0.5rem;">
        <input type="hidden" name="type" value="ts">
        <input type="number" name="quota" value="<%= currentRound.quota_ts >= 999 ? 1 : currentRound.quota_ts %>" min="1" max="999" style="width: 80px;">
        <button type="submit" class="btn btn-secondary">Set TS</button>
      </form>
      <div style="display: flex; gap: 0.5rem; margin-top: 0.5rem;">
        <form action="/reservations/quota" method="POST">
          <input type="hidden" name="type" value="ts">
          <input type="hidden" name="quota" value="999">
          <button type="submit" class="btn btn-blue" style="padding: 0.3rem 0.6rem; font-size: 0.75rem;">Unlimited</button>
        </form>
      </div>
    </div>
  </div>
</div>

<div class="card" style="border-left: 4px solid var(--primary);">
  <h3 style="margin-bottom: 1.5rem;">Manual Reservation (Admin)</h3>
  <form action="/reservations" method="POST" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 1rem; align-items: flex-end;">
    <div class="form-group" style="margin-bottom: 0;">
      <label for="item_id">Select Item</label>
      <select id="item_id" name="item_id" required>
        <option value="" disabled selected>Select available item...</option>
        <% for(let item of availableItems) { %>
          <option value="<%= item.id %>">Page: <%= item.page_name %> - Position: <%= item.position %> (<%= displayItemType(item.item_type) %>)</option>
        <% } %>
      </select>
    </div>
    <div class="form-group" style="margin-bottom: 0;">
      <label for="discord_user_id">Select User (from Whitelist)</label>
      <input type="text" id="discord_user_id" name="discord_user_id" list="whitelist-users" required placeholder="Type name or ID...">
      <datalist id="whitelist-users">
        <% for(let u of whitelist) { %>
          <option value="<%= u.discord_user_id %>"><%= u.discord_username %></option>
        <% } %>
      </datalist>
    </div>
    <button class="btn btn-primary" type="submit">Confirm Reservation</button>
  </form>
</div>

<div class="card">
  <h3 style="margin-bottom: 1.5rem;">Active Reservations in Current Round</h3>
  <% if (reservations.length === 0) { %>
    <div style="text-align: center; padding: 3rem 1rem;">
      <div style="font-size: 3rem; margin-bottom: 1rem;">📭</div>
      <p style="color: var(--text-light); font-style: italic;">No active reservations in this round.</p>
    </div>
  <% } else { %>
    <div class="table-responsive">
      <table>
        <thead>
          <tr>
            <th>Time</th>
            <th>Member</th>
            <th>Discord ID</th>
            <th>Details</th>
            <th style="text-align: right;">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% for(let r of reservations) { %>
            <tr>
              <td><%= new Date(r.reserved_at).toLocaleTimeString('th-TH', { hour: '2-digit', minute: '2-digit' }) %></td>
              <td><strong><%= r.discord_username %></strong></td>
              <td><code style="font-size: 0.85rem;"><%= r.discord_user_id %></code></td>
              <td>
                <span class="badge badge-blue">Page <%= r.page_name %></span>
                <span style="font-size: 0.85rem; color: var(--text-light);"><%= r.item_display_name %></span>
              </td>
              <td style="text-align: right;">
                <form action="/reservations/<%= r.id %>/delete" method="POST" style="display:inline;" onsubmit="return confirm('Cancel this reservation?');">
                  <button type="submit" class="btn btn-secondary" style="color: var(--danger); font-size: 0.85rem; padding: 0.4rem 0.8rem;">Cancel</button>
                </form>
              </td>
            </tr>
          <% } %>

        </tbody>
      </table>
    </div>
  <% } %>
</div>
