<div class="flex space-between flex-desktop items-center" style="margin-bottom: 2rem;">
  <div>
    <h1>Admin Dashboard</h1>
    <% if (user.server_name || user.discord_username) { %>
      <p style="color: var(--text-light); margin: 0;">Welcome, <%= user.server_name || user.discord_username %></p>
    <% } else { %>
      <p style="color: var(--text-light); margin: 0;">Welcome, Admin</p>
    <% } %>
  </div>
  <div style="margin-top: 1rem;">
    <div id="round-status-container">
      <% if (round && round.status === 'preparing') { %>
        <div style="display: flex; gap: 1rem; align-items: center;">
          <span class="badge" style="background: #fef3c7; color: #92400e; font-size: 0.9rem; padding: 0.5rem 1rem;">Preparing</span>
          <form action="/round/open" method="POST" onsubmit="return handleFormLoading(this, 'Start the round? The bot will post to Discord immediately.', 'Opening...');">
            <button type="submit" class="btn btn-primary" style="background: var(--success);">
              Start Round
            </button>
          </form>
        </div>
      <% } else if (round && round.status === 'open') { %>
        <div style="display: flex; gap: 1rem; align-items: center;">
          <span class="badge" style="background: #d1fae5; color: #065f46; font-size: 0.9rem; padding: 0.5rem 1rem;">OPEN</span>
          <form action="/round/close" method="POST" onsubmit="return handleFormLoading(this, 'End the round?', 'Closing...');">
            <button type="submit" class="btn btn-danger">
              End Round
            </button>
          </form>
        </div>
      <% } %>
    </div>
  </div>
</div>

<script>
  function handleFormLoading(form, confirmMsg, loadingText) {
    if (confirm(confirmMsg)) {
      const btn = form.querySelector('button[type="submit"]');
      if (btn) {
        btn.innerText = loadingText;
        btn.disabled = true;
        btn.style.opacity = '0.7';
        btn.style.cursor = 'wait';
      }
      return true;
    }
    return false;
  }
</script>

<!-- Stats Overview -->
<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem; margin-bottom: 2.5rem;">
  <div class="card" style="margin-bottom: 0; display: flex; align-items: center; gap: 1.5rem;">
    <div style="background: #eff6ff; color: #3b82f6; width: 60px; height: 60px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1.5rem;">📋</div>
    <div>
      <h3 style="color: var(--text-light); font-size: 0.85rem; text-transform: uppercase; margin: 0; letter-spacing: 0.05em;">Reserved</h3>
      <div id="stats-reserved" style="font-size: 2rem; font-weight: 800; color: var(--text); line-height: 1.2;"><%= reservationsCount %></div>
    </div>
  </div>
  
  <div class="card" style="margin-bottom: 0; display: flex; align-items: center; gap: 1.5rem;">
    <div style="background: #f0fdf4; color: #10b981; width: 60px; height: 60px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1.5rem;">📑</div>
    <div>
      <h3 style="color: var(--text-light); font-size: 0.85rem; text-transform: uppercase; margin: 0; letter-spacing: 0.05em;">Pages</h3>
      <div id="stats-pages" style="font-size: 2rem; font-weight: 800; color: var(--text); line-height: 1.2;"><%= pagesCount %></div>
    </div>
  </div>
  
  <div class="card" style="margin-bottom: 0; display: flex; align-items: center; gap: 1.5rem;">
    <div style="background: #f5f3ff; color: #8b5cf6; width: 60px; height: 60px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1.5rem;">🛡️</div>
    <div>
      <h3 style="color: var(--text-light); font-size: 0.85rem; text-transform: uppercase; margin: 0; letter-spacing: 0.05em;">Whitelist</h3>
      <div id="stats-whitelist" style="font-size: 2rem; font-weight: 800; color: var(--text); line-height: 1.2;"><%= whitelistCount %></div>
    </div>
  </div>
</div>

<!-- Click Quota Management (Visible only when round is open) -->
<% if (round && round.status === 'open') { %>
<div class="card" style="border-left: 4px solid var(--primary); margin-bottom: 2.5rem; background: #f0fdf4;">
  <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 2rem;">
    <div>
      <h3 style="margin: 0; color: #065f46;">🖱️ Button Click Quota</h3>
      <p style="color: var(--text-light); font-size: 0.85rem; margin-top: 0.25rem;">
        Limit how many buttons a user can click. Current: <strong style="color: #059669;"><%= round.quota >= 999 ? 'Unlimited' : round.quota + ' Clicks' %></strong>
      </p>
      <div style="display: flex; gap: 0.75rem; margin-top: 1rem; flex-wrap: wrap;">
        <form action="/reservations/quota" method="POST">
          <input type="hidden" name="quota" value="<%= round.quota >= 999 ? 2 : round.quota + 1 %>">
          <button type="submit" class="btn" style="background: #10b981; color: white; padding: 0.6rem 1.2rem; font-weight: bold; border-radius: 8px; box-shadow: 0 4px 6px -1px rgba(16, 185, 129, 0.3);">+1 Click</button>
        </form>
        <form action="/reservations/quota" method="POST" onsubmit="return confirm('Reset click quota to 1?');">
          <input type="hidden" name="quota" value="1">
          <button type="submit" class="btn btn-secondary" style="padding: 0.6rem 1.2rem; font-weight: bold; border-radius: 8px;">🔄 Reset</button>
        </form>
        <form action="/reservations/quota" method="POST" onsubmit="return confirm('Set click quota to UNLIMITED? Users will be able to click as many times as they want.');">
          <input type="hidden" name="quota" value="999">
          <button type="submit" class="btn btn-blue" style="padding: 0.6rem 1.2rem; font-weight: bold; border-radius: 8px;">Unlimited</button>
        </form>
      </div>
    </div>
  </div>
</div>
<% } %>

<!-- Feather Quota Management (Visible only if round is NOT open AND items exist) -->
<% if (round && round.status !== 'open' && pagesCount > 0) { %>
<div class="card" style="border-left: 4px solid var(--secondary); margin-bottom: 2.5rem; background: #fffcf8;">
  <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 2rem;">
    <!-- Light-Dark Quota -->
    <div>
      <h3 style="margin: 0;">🤍 LD Quota (White)</h3>
      <p style="color: var(--text-light); font-size: 0.85rem; margin-top: 0.25rem;">
        Limit: <strong style="color: #059669;"><%= round.quota_ld >= 999 ? 'Unlimited' : round.quota_ld + ' items' %></strong>
      </p>
      <form action="/reservations/quota" method="POST" style="margin-top: 1rem; display: flex; gap: 0.5rem;">
        <input type="hidden" name="type" value="ld">
        <input type="number" name="quota" value="<%= round.quota_ld >= 999 ? 1 : round.quota_ld %>" min="1" max="999" class="form-control" style="width: 100px; padding: 0.4rem;">
        <button type="submit" class="btn btn-secondary" style="padding: 0.4rem 0.8rem; font-size: 0.85rem;">Set LD</button>
      </form>
      <div style="display: flex; gap: 0.5rem; margin-top: 0.5rem; flex-wrap: wrap;">
        <form action="/reservations/quota" method="POST">
          <input type="hidden" name="type" value="ld">
          <input type="hidden" name="quota" value="999">
          <button type="submit" class="btn btn-blue" style="padding: 0.3rem 0.6rem; font-size: 0.75rem;">Unlimited</button>
        </form>
      </div>
    </div>

    <!-- Time-Space Quota -->
    <div>
      <h3 style="margin: 0;">❤️ TS Quota (Red)</h3>
      <p style="color: var(--text-light); font-size: 0.85rem; margin-top: 0.25rem;">
        Limit: <strong style="color: #dc2626;"><%= round.quota_ts >= 999 ? 'Unlimited' : round.quota_ts + ' items' %></strong>
      </p>
      <form action="/reservations/quota" method="POST" style="margin-top: 1rem; display: flex; gap: 0.5rem;">
        <input type="hidden" name="type" value="ts">
        <input type="number" name="quota" value="<%= round.quota_ts >= 999 ? 1 : round.quota_ts %>" min="1" max="999" class="form-control" style="width: 100px; padding: 0.4rem;">
        <button type="submit" class="btn btn-secondary" style="padding: 0.4rem 0.8rem; font-size: 0.85rem;">Set TS</button>
      </form>
      <div style="display: flex; gap: 0.5rem; margin-top: 0.5rem; flex-wrap: wrap;">
        <form action="/reservations/quota" method="POST">
          <input type="hidden" name="type" value="ts">
          <input type="hidden" name="quota" value="999">
          <button type="submit" class="btn btn-blue" style="padding: 0.3rem 0.6rem; font-size: 0.75rem;">Unlimited</button>
        </form>
      </div>
    </div>
  </div>
  <p style="margin-top: 1.5rem; font-size: 0.75rem; color: #94a3b8; border-top: 1px solid #fee2e2; padding-top: 1rem;">
    *Albums and Boxes remain managed via spin wheel only. Users cannot reserve them directly on Discord.*
  </p>
</div>
<% } %>

<!-- Setup Sections (Show only if NOT open) -->
<% if (round && round.status !== 'open') { %>
<script>
  function showFullLoading(message) {
      const overlay = document.createElement('div');
      overlay.style.position = 'fixed';
      overlay.style.top = '0';
      overlay.style.left = '0';
      overlay.style.width = '100vw';
      overlay.style.height = '100vh';
      overlay.style.backgroundColor = 'rgba(255, 255, 255, 0.8)';
      overlay.style.zIndex = '9999';
      overlay.style.display = 'flex';
      overlay.style.flexDirection = 'column';
      overlay.style.justifyContent = 'center';
      overlay.style.alignItems = 'center';
      
      const spinner = document.createElement('div');
      spinner.innerHTML = '⏳';
      spinner.style.fontSize = '4rem';
      spinner.style.animation = 'spin 2s linear infinite';
      
      const text = document.createElement('h2');
      text.innerText = message;
      text.style.color = 'var(--primary)';
      text.style.marginTop = '1rem';
      
      overlay.appendChild(spinner);
      overlay.appendChild(text);
      document.body.appendChild(overlay);

      if (!document.getElementById('spinner-style')) {
        const style = document.createElement('style');
        style.id = 'spinner-style';
        style.innerHTML = '@keyframes spin { 100% { transform: rotate(360deg); } }';
        document.head.appendChild(style);
      }
  }

  function applyPreset() {
    const selector = document.getElementById('preset-selector');
    const id = selector.value;
    if (!id) return alert('Please select a Preset');
    
    if (confirm('Apply this preset? (Automatically creates pages and items)')) {
      showFullLoading('Applying Preset...');
      const form = document.getElementById('apply-preset-form');
      form.action = '/presets/apply/' + id;
      form.submit();
    }
  }

  function handleMultiplyForm(pctMsg) {
    if (confirm(pctMsg + ' System will recalculate all items and re-sort the board.')) {
      showFullLoading('Recalculating...');
      return true;
    }
    return false;
  }
</script>

  <% if (pagesCount === 0) { %>
<div class="card" style="background: #fcfaff; border: 1px dashed var(--primary); margin-bottom: 2.5rem;">
  <div class="flex items-center space-between flex-desktop">
    <div>
      <h3 style="margin: 0;">⚡ Fast Setup: Apply Item Preset</h3>
      <p style="color: var(--text-light); font-size: 0.85rem; margin-top: 0.25rem;">Create all pages and items in one click using a saved preset template.</p>
    </div>
    <div style="margin-top: 1rem;">
      <form action="" id="apply-preset-form" method="POST" class="flex gap-1">
        <select id="preset-selector" class="form-control" style="min-width: 250px; padding: 0.6rem;">
          <option value="">-- Select Preset --</option>
          <% presets.forEach(p => { %>
            <option value="<%= p.id %>"><%= p.name %> (<%- ICONS.ALBUM %>:<%= p.album_count %>, <%- ICONS.ILLUTION_BOX %>:<%= p.illution_box_count || 0 %>, <%- ICONS.LIGHT_DARK %>:<%= p.light_dark_count %>, <%- ICONS.TIME_SPACE %>:<%= p.time_space_count %>)</option>
          <% }) %>
        </select>
        <button type="button" class="btn" onclick="applyPreset()" style="background: var(--primary);">Apply</button>
      </form>
      <a href="/presets" style="font-size: 0.75rem; color: var(--primary); display: block; margin-top: 0.5rem; text-align: right;">+ Create/Manage Presets</a>
    </div>
  </div>
</div>
  <% } else { %>
<!-- Multiply Items Section -->
<div class="card" style="background: #f0fdf4; border: 1px dashed #10b981; margin-bottom: 2.5rem;">
  <div class="flex items-center space-between flex-desktop">
    <div>
      <h3 style="margin: 0; color: #065f46;">📈 Multiply / Boost Items</h3>
      <p style="color: var(--text-light); font-size: 0.85rem; margin-top: 0.25rem;">Multiply current inventory by a percentage (rounded down).</p>
    </div>
    <div style="margin-top: 1rem; flex-wrap: wrap; align-items: center;" class="flex gap-1">
      <form action="/pages/multiply" method="POST" onsubmit="return handleMultiplyForm('Increase inventory by 50%?');">
        <input type="hidden" name="percentage" value="50">
        <button type="submit" class="btn" style="background: #10b981; color: white;">+50%</button>
      </form>
      <form action="/pages/multiply" method="POST" onsubmit="return handleMultiplyForm('Increase inventory by 70%?');">
        <input type="hidden" name="percentage" value="70">
        <button type="submit" class="btn" style="background: #10b981; color: white;">+70%</button>
      </form>
      <form action="/pages/multiply" method="POST" onsubmit="return handleMultiplyForm('Double inventory?');">
        <input type="hidden" name="percentage" value="100">
        <button type="submit" class="btn" style="background: #059669; color: white;">+100% (x2)</button>
      </form>
      <form action="/pages/multiply" method="POST" class="flex gap-1" onsubmit="return handleMultiplyForm('Apply custom percentage?');">
        <input type="number" name="percentage" placeholder="Custom %" min="1" max="1000" class="form-control" style="width: 110px; padding: 0.6rem;" required>
        <button type="submit" class="btn" style="background: var(--text); color: white;">Apply %</button>
      </form>
      <div style="width: 1px; height: 30px; background: #cbd5e1; margin: 0 0.5rem;"></div>
      <form action="/pages/delete-all?redirect=/" method="POST" onsubmit="return confirm('Wipe all items and reset?');">
        <button type="submit" class="btn btn-outline" style="color: var(--danger); border-color: var(--danger); background: white;">🗑️ Reset Board</button>
      </form>
    </div>
  </div>
</div>
  <% } %>
<% } %>

<!-- Live Progress -->
<div class="card">
  <div class="flex space-between items-center" style="margin-bottom: 2rem;">
    <div>
      <h3 style="margin: 0;">Live Progress / Items Overview</h3>
      <p style="color: var(--text-light); font-size: 0.85rem; margin-top: 0.25rem;">Updates every 5 seconds • <span id="last-update" style="font-weight: 600;">Loading...</span></p>
    </div>
    <div style="text-align: right;" id="progress-badges">
       <span class="badge badge-success"><%= reservationsCount %> RESERVED</span>
       <span class="badge badge-gray"><%= (pagesCount * 4) - reservationsCount %> REMAINING</span>
    </div>
  </div>

  <div id="pages-container" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 1.5rem;">
    <!-- Will be filled by JS or initial Load -->
    <% for(let p of pagesWithItems) { %>
      <div class="page-card" style="border: 1px solid #e2e8f0; border-radius: 12px; overflow: hidden;">
        <div style="background: #f8fafc; padding: 0.75rem 1rem; border-bottom: 1px solid #e2e8f0; display: flex; justify-content: space-between;">
          <strong style="color: var(--primary);">Page <%= p.name %></strong>
          <span style="font-size: 0.75rem; color: var(--text-light);"><%= p.items.filter(i => i.reserved_by).length %>/4</span>
        </div>
        <div style="padding: 0.5rem;">
          <% for(let i of p.items) { %>
            <div style="padding: 0.6rem 0.75rem; border-radius: 8px; margin-bottom: 0.25rem; font-size: 0.85rem; display: flex; justify-content: space-between; align-items: center; background: <%= i.reserved_by ? '#eff6ff' : '#ffffff' %>; border: 1px solid <%= i.reserved_by ? '#dbeafe' : 'transparent' %>;">
              <span style="font-weight: 500;"><%= i.position %>. <%= displayItemType(i.item_type) %></span>
              <% if (i.reserved_by) { %>
                <span style="color: var(--primary); font-weight: 700;">👤 <%= i.reserved_by %></span>
              <% } else { %>
                <span style="color: #cbd5e1;">Available</span>
              <% } %>
            </div>
          <% } %>
        </div>
      </div>
    <% } %>
  </div>
</div>

<script>
  const ITEM_TYPE_DISPLAY = { 
    'Album':      '<%- ITEM_TYPES["Album"] ? ITEM_TYPES["Album"].emoji + " " + ITEM_TYPES["Album"].label : "Album" %>', 
    'Illution Box': '<%- ITEM_TYPES["Illution Box"] ? ITEM_TYPES["Illution Box"].emoji + " " + ITEM_TYPES["Illution Box"].label : "Box" %>',
    'illution-box': '<%- ITEM_TYPES["Illution Box"] ? ITEM_TYPES["Illution Box"].emoji + " " + ITEM_TYPES["Illution Box"].label : "Box" %>',
    'Light-Dark': '<%- ITEM_TYPES["Light-Dark"] ? ITEM_TYPES["Light-Dark"].emoji + " " + ITEM_TYPES["Light-Dark"].label : "Light-Dark" %>', 
    'Time-Space': '<%- ITEM_TYPES["Time-Space"] ? ITEM_TYPES["Time-Space"].emoji + " " + ITEM_TYPES["Time-Space"].label : "Time-Space" %>',
    'light-dark': '<%- ITEM_TYPES["light-dark"] ? ITEM_TYPES["light-dark"].emoji + " " + ITEM_TYPES["light-dark"].label : "Light-Dark" %>',
    'time-space': '<%- ITEM_TYPES["time-space"] ? ITEM_TYPES["time-space"].emoji + " " + ITEM_TYPES["time-space"].label : "Time-Space" %>'
  };
  const displayType = (t) => ITEM_TYPE_DISPLAY[t] || t;

  async function refreshDashboard() {
    try {
      const response = await fetch('/api/dashboard-stats');
      const data = await response.json();
      
      // Update Stats
      document.getElementById('stats-reserved').innerText = data.reservationsCount;
      document.getElementById('stats-pages').innerText = data.pagesCount;
      document.getElementById('stats-whitelist').innerText = data.whitelistCount;
      
      // Update Badges
      const remaining = (data.pagesCount * 4) - data.reservationsCount;
      document.getElementById('progress-badges').innerHTML = `
        <span class="badge badge-success">${data.reservationsCount} RESERVED</span>
        <span class="badge badge-gray">${remaining} REMAINING</span>
      `;
      
      // Update Pages Container
      const container = document.getElementById('pages-container');
      if (data.pagesWithItems.length === 0) {
        container.innerHTML = '<div style="text-align: center; padding: 2rem; color: var(--text-light); border: 2px dashed #e2e8f0; border-radius: 12px; grid-column: 1/-1;">No pages created yet</div>';
      } else {
        const pagesHtml = data.pagesWithItems.map(p => {
          const reservedCount = p.items.filter(i => i.reserved_by).length;
          const itemsHtml = p.items.map(i => `
            <div style="padding: 0.6rem 0.75rem; border-radius: 8px; margin-bottom: 0.25rem; font-size: 0.85rem; display: flex; justify-content: space-between; align-items: center; background: ${i.reserved_by ? '#eff6ff' : '#ffffff'}; border: 1px solid ${i.reserved_by ? '#dbeafe' : 'transparent'};">
              <span style="font-weight: 500;">${i.position}. ${displayType(i.item_type)}</span>
              ${i.reserved_by ? `<span style="color: var(--primary); font-weight: 700;">👤 ${i.reserved_by}</span>` : `<span style="color: #cbd5e1;">Available</span>`}
            </div>
          `).join('');
          
          return `
            <div class="page-card" style="border: 1px solid #e2e8f0; border-radius: 12px; overflow: hidden;">
              <div style="background: #f8fafc; padding: 0.75rem 1rem; border-bottom: 1px solid #e2e8f0; display: flex; justify-content: space-between;">
                <strong style="color: var(--primary);">Page ${p.name}</strong>
                <span style="font-size: 0.75rem; color: var(--text-light);">${reservedCount}/4</span>
              </div>
              <div style="padding: 0.5rem;">${itemsHtml}</div>
            </div>
          `;
        }).join('');
        container.innerHTML = pagesHtml;
      }
      
      document.getElementById('last-update').innerText = 'Last updated: ' + new Date().toLocaleTimeString();
    } catch (err) {
      console.error('Failed to refresh dashboard:', err);
      document.getElementById('last-update').innerText = 'Connection lost...';
    }
  }

  // Refresh every 5 seconds
  setInterval(refreshDashboard, 5000);
  document.getElementById('last-update').innerText = 'Connected';
</script>
