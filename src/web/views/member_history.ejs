<div class="flex space-between items-center" style="margin-bottom: 2rem;">
  <div>
    <a href="/whitelist" style="text-decoration: none; color: var(--primary); font-size: 0.9rem; display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.5rem;">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
        กลับไปหน้า Whitelist
    </a>
    <h1>History: <%= member.discord_username %></h1>
  </div>
  <div style="text-align: right;">
    <div style="font-size: 0.8rem; color: var(--text-light); text-transform: uppercase;">Overall Luck</div>
    <div style="font-size: 1.5rem; font-weight: 700; color: var(--primary);">
        <%= member.spin_count > 0 ? Math.round((member.win_count / member.spin_count) * 100) : 0 %>%
    </div>
  </div>
</div>

<div class="card">
  <div class="flex-desktop flex space-between items-center" style="margin-bottom: 2rem;">
    <div>
        <h3 style="margin: 0;">Lottery Results Timeline</h3>
        <p style="color: var(--text-light); font-size: 0.9rem;">ประวัติการสุ่มทั้งหมดที่ผู้เล่นคนนี้เข้ารวม</p>
    </div>
    <div class="flex" style="gap: 2rem;">
        <div style="text-align: center;">
            <div style="font-size: 0.8rem; color: var(--text-light);">TOTAL SPINS</div>
            <div style="font-size: 1.25rem; font-weight: 700;"><%= member.spin_count %></div>
        </div>
        <div style="text-align: center;">
            <div style="font-size: 0.8rem; color: var(--text-light);">TOTAL WINS</div>
            <div style="font-size: 1.25rem; font-weight: 700; color: var(--success);"><%= member.win_count %></div>
        </div>
    </div>
  </div>

  <div class="table-responsive">
    <table>
      <thead>
        <tr>
          <th>Date & Time</th>
          <th>Result</th>
          <th>Details</th>
        </tr>
      </thead>
      <tbody>
        <% if (history.length === 0) { %>
          <tr>
            <td colspan="3" style="text-align: center; padding: 3rem; color: var(--text-light);">ยังไม่มีประวัติการร่วมสุ่ม</td>
          </tr>
        <% } else { %>
          <% for(let entry of history) { %>
            <tr>
              <td style="font-weight: 500;">
                <%= new Date(entry.created_at).toLocaleString('th-TH') %>
              </td>
              <td>
                <% if (entry.is_winner) { %>
                    <span class="badge badge-success">✅ WINNER</span>
                <% } else { %>
                    <span class="badge badge-gray">❌ NOT SELECTED</span>
                <% } %>
              </td>
              <td style="color: var(--text-light); font-size: 0.9rem;">
                Participated in lottery session
              </td>
            </tr>
          <% } %>
        <% } %>
      </tbody>
    </table>
  </div>
</div>
