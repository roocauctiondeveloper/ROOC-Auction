<div class="flex space-between items-center" style="margin-bottom: 2rem;">
  <h1>Pages Management</h1>
</div>

<div class="grid" style="gap: 1.5rem; margin-bottom: 2rem;">
  <!-- Bulk Reset & Setup -->
  <div class="card" style="border: 2px solid #e0e7ff; background: linear-gradient(135deg, #ffffff 0%, #f5f7ff 100%); margin: 0;">
    <div style="display: flex; align-items: flex-start; gap: 1rem; margin-bottom: 1.5rem;">
      <div style="background: var(--primary); color: white; width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 1.25rem;">🚀</div>
      <div>
        <h3 style="color: var(--primary); margin: 0;">Bulk Reset & Setup</h3>
        <p style="color: var(--text-light); font-size: 0.875rem; margin-top: 0.25rem;">
          Clears everything and creates new pages sorted by type (Album &raquo; Box &raquo; LD &raquo; TS)
        </p>
      </div>
    </div>
    
    <form action="/pages/bulk-setup" method="POST" onsubmit="return handleFormSubmit(this, 'WARNING: This will DELETE all existing pages and items. Continue?', 'Setting up...');">
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1.5rem;">
        <div class="form-group" style="margin-bottom: 0;">
          <label><%- ICONS.ALBUM %> Album</label>
          <input type="number" name="card_total" min="0" value="0" required>
        </div>
        <div class="form-group" style="margin-bottom: 0;">
          <label><%- ICONS.ILLUTION_BOX %> Box</label>
          <input type="number" name="box_total" min="0" value="0" required>
        </div>
        <div class="form-group" style="margin-bottom: 0;">
          <label><%- ICONS.LIGHT_DARK %> LD</label>
          <input type="number" name="white_total" min="0" value="0" required>
        </div>
        <div class="form-group" style="margin-bottom: 0;">
          <label><%- ICONS.TIME_SPACE %> TS</label>
          <input type="number" name="black_total" min="0" value="0" required>
        </div>
      </div>
      <button class="btn btn-primary" type="submit" style="width: 100%; box-shadow: 0 4px 14px 0 rgba(99, 102, 241, 0.39);">Wipe & Generate All</button>
    </form>
  </div>

  <!-- Add to Current -->
  <div class="card" style="border: 2px solid #ecfdf5; background: linear-gradient(135deg, #ffffff 0%, #f0fdf4 100%); margin: 0;">
    <div style="display: flex; align-items: flex-start; gap: 1rem; margin-bottom: 1.5rem;">
      <div style="background: var(--success); color: white; width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 1.25rem;">➕</div>
      <div>
        <h3 style="color: var(--success); margin: 0;">Add Items to Current</h3>
        <p style="color: var(--text-light); font-size: 0.875rem; margin-top: 0.25rem;">
          Inject items into current inventory and re-sort all pages.
        </p>
      </div>
    </div>
    
    <form action="/pages/bulk-add" method="POST" onsubmit="return handleFormSubmit(this, 'Inject these items and re-sort all pages?', 'Injecting...');">
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1.5rem;">
        <div class="form-group" style="margin-bottom: 0;">
          <label><%- ICONS.ALBUM %> +Album</label>
          <input type="number" name="card_add" min="0" value="0" required>
        </div>
        <div class="form-group" style="margin-bottom: 0;">
          <label><%- ICONS.ILLUTION_BOX %> +Box</label>
          <input type="number" name="box_add" min="0" value="0" required>
        </div>
        <div class="form-group" style="margin-bottom: 0;">
          <label><%- ICONS.LIGHT_DARK %> +LD</label>
          <input type="number" name="white_add" min="0" value="0" required>
        </div>
        <div class="form-group" style="margin-bottom: 0;">
          <label><%- ICONS.TIME_SPACE %> +TS</label>
          <input type="number" name="black_add" min="0" value="0" required>
        </div>
      </div>
      <button id="inject-btn" class="btn" style="width: 100%; background: var(--success); border: none; color: white; box-shadow: 0 4px 14px 0 rgba(16, 185, 129, 0.39);">Inject & Re-sort</button>
    </form>
  </div>
</div>

<script>
  function handleFormSubmit(form, confirmMsg, loadingText) {
    if (!confirm(confirmMsg)) return false;
    const btn = form.querySelector('button[type="submit"]') || form.querySelector('.btn');
    if (btn) {
      btn.innerHTML = `⏳ ${loadingText}`;
      btn.disabled = true;
      btn.style.opacity = '0.7';
      btn.style.cursor = 'wait';
    }
    return true;
  }
</script>

<div class="card">
  <div class="flex space-between items-center" style="margin-bottom: 1.5rem;">
    <h3 style="margin: 0;">All Pages (<%= pages.length %>)</h3>
    <% if (pages.length > 0) { %>
      <form action="/pages/delete-all" method="POST" class="ajax-delete" data-confirm="Are you sure you want to delete ALL pages and items?">
        <button type="submit" class="btn btn-secondary" style="color: var(--danger); font-size: 0.85rem; padding: 0.4rem 0.8rem;">Delete All</button>
      </form>
    <% } %>
  </div>
  <% if (pages.length === 0) { %>
    <div style="text-align: center; padding: 3rem 1rem;">
      <p style="color: var(--text-light); font-style: italic;">No pages found. Use Bulk Setup or Preset to create pages.</p>
    </div>
  <% } else { %>
    <div class="table-responsive">
      <table>
        <thead>
          <tr>
            <th>Page ID</th>
            <th>Name</th>
            <th>Items Status</th>
            <th style="text-align: right;">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% for(let p of pages) { %>
            <tr>
              <td><span style="color: var(--text-light); font-family: monospace;">#<%= p.id %></span></td>
              <td><strong style="font-size: 1.1rem;">Page <%= p.name %></strong></td>
              <td>
                <div style="display: flex; align-items: center; gap: 0.75rem;">
                  <div style="flex: 1; min-width: 80px; height: 8px; background: #f1f5f9; border-radius: 10px; overflow: hidden; display: block;">
                    <div style="width: <%= (p.item_count / 4) * 100 %>%; height: 100%; background: <%= p.item_count === 4 ? 'var(--success)' : 'var(--primary)' %>;"></div>
                  </div>
                  <span style="font-size: 0.85rem; font-weight: 600; color: var(--text-light);"><%= p.item_count %>/4</span>
                </div>
              </td>
              <td style="text-align: right;">
                <div style="display: flex; gap: 0.5rem; justify-content: flex-end;">
                  <a href="/items/page/<%= p.id %>" class="btn btn-secondary" style="font-size: 0.85rem; padding: 0.4rem 0.8rem;">Edit Items</a>
                  <form action="/pages/<%= p.id %>/delete" method="POST" class="ajax-delete" data-confirm="Delete this page and all items?" style="display:inline;">
                    <button type="submit" class="btn btn-secondary" style="color: var(--danger); font-size: 0.85rem; padding: 0.4rem 0.8rem;">Delete</button>
                  </form>
                </div>
              </td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>
