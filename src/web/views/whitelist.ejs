<link rel="stylesheet" href="/css/lottery.css">

<div class="flex space-between items-center" style="margin-bottom: 2rem;">
  <h1>Whitelist & Selection</h1>
</div>

<div class="card" style="border-left: 4px solid var(--primary);">
  <h3 style="margin-bottom: 1.5rem;">Add New Member</h3>
  <p style="color: var(--text-light); margin-bottom: 1rem; font-size: 0.9rem;">
    💡 Enter the <b>Discord User ID</b> and the system will automatically fetch the username.
  </p>
  <form action="/whitelist" method="POST" style="display: flex; gap: 1rem; align-items: flex-end;">
    <div class="form-group" style="margin-bottom: 0; flex-grow: 1;">
      <label for="discord_user_id">Discord User ID</label>
      <input type="text" id="discord_user_id" name="discord_user_id" required placeholder="Example: 123456789012345678">
    </div>
    <button class="btn btn-primary" type="submit">Add User</button>
  </form>
</div>

<!-- 🎡 Spin Wheel Section -->
<div class="card lottery-section" style="background: linear-gradient(to bottom, #ffffff, #f8fafc);">
    <div class="flex-desktop flex space-between items-center" style="margin-bottom: 2rem;">
        <div>
            <h3 style="margin: 0; font-family: 'Outfit';">🎡 Whitelist Lottery (Gacha Mode)</h3>
            <p style="color: var(--text-light); font-size: 0.85rem;">Randomly select members one by one!</p>
        </div>
        <div class="lottery-controls">
            <div style="background: #f1f5f9; padding: 0.5rem 1rem; border-radius: 12px; border: 1px solid #e2e8f0; display: flex; align-items: center; gap: 1rem;">
                <span style="font-weight: 600; font-size: 0.9rem;">Winner Count:</span>
                <input type="number" id="lottery-count" value="1" min="1" max="<%= whitelist.length %>" style="width: 60px; border:none; background:transparent; font-weight: 700; color: var(--primary); font-size: 1.1rem;">
                <button class="btn btn-primary" onclick="startLottery()" id="spin-btn" style="border-radius: 10px; box-shadow: 0 4px 6px rgba(99, 102, 241, 0.3);">🔥 Spin!</button>
            </div>
        </div>
    </div>

    <div class="lottery-layout" style="display: grid; grid-template-columns: 1.2fr 0.8fr; gap: 2rem; align-items: start;">
        <!-- Left: The Wheel -->
        <div class="wheel-container" style="background: transparent; padding: 0; position: relative; margin: 0;">
            <canvas id="wheel-canvas" width="450" height="450" style="width: 100%; max-width: 450px;"></canvas>
            <div class="wheel-pointer" style="right: -10px;"></div>
        </div>

        <!-- Right: Winner List / Timeline -->
        <div class="results-container">
            <div id="lottery-status" style="margin-bottom: 1rem; font-weight: 700; color: var(--text-light); text-transform: uppercase; font-size: 0.8rem; letter-spacing: 0.1em;">
                Waiting to start...
            </div>
            <div id="winners-timeline" style="display: flex; flex-direction: column; gap: 0.75rem; min-height: 300px; padding: 1rem; background: #f8fafc; border-radius: var(--radius); border: 2px dashed #e2e8f0;">
                <!-- Winners appear here one by one -->
                <div style="text-align: center; color: #94a3b8; margin-top: 5rem;">Winners list will appear here...</div>
            </div>

            <!-- Final Action (hidden until end) -->
            <div id="final-actions" style="display: none; margin-top: 1.5rem; animation: celebrate 0.5s ease-out;">
                <form id="lottery-form" onsubmit="applyLottery(event)">
                    <div id="winners-hidden-input"></div>
                    <button type="submit" id="confirm-winners-btn" class="btn btn-primary" style="width: 100%; padding: 1rem; font-size: 1.1rem;">✅ Confirm All Winners</button>
                </form>
                <button type="button" onclick="resetLottery()" class="btn btn-secondary" style="width: 100%; margin-top: 0.5rem;">Cancel & Reset</button>
            </div>
        </div>
    </div>
</div>

<div class="card">
  <div class="flex space-between items-center" style="margin-bottom: 1.5rem;">
    <h3 style="margin: 0;">Members Management (<%= whitelist.length %>)</h3>
  </div>
  
  <div class="table-responsive">
    <table>
      <thead>
        <tr>
          <th style="width: 40px;"><input type="checkbox" id="select-all" checked onchange="toggleSelectAll(this)"></th>
          <th>Status</th>
          <th>User Info</th>
          <th>Luck / Stats</th>
          <th>Discord ID</th>
          <th style="text-align: right;">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% if (whitelist.length === 0) { %>
          <tr>
            <td colspan="6" style="text-align: center; padding: 3rem 1rem; color: var(--text-light);">No users found.</td>
          </tr>
        <% } else { %>
          <% for(let user of whitelist) { 
             const winRate = user.spin_count > 0 ? Math.round((user.win_count / user.spin_count) * 100) : 0;
             let luckColor = 'var(--text-light)';
             if (winRate >= 50) luckColor = 'var(--success)';
             else if (winRate > 0 && winRate < 20) luckColor = 'var(--danger)';
          %>
            <tr id="row-<%= user.id %>" style="<%= user.is_active ? '' : 'opacity: 0.6; background-color: #f8fafc;' %> transition: opacity 0.3s;">
              <td>
                <input type="checkbox" class="participant-checkbox" value="<%= user.id %>" data-username="<%= user.discord_username %>" checked onchange="updateWheelFromSelection()">
              </td>
              <td style="width: 120px;">

                <button 
                    onclick="toggleStatus('<%= user.id %>', <%= user.is_active %>)" 
                    id="btn-status-<%= user.id %>"
                    class="badge <%= user.is_active ? 'badge-success' : 'badge-gray' %>" 
                    style="border:none; cursor:pointer;" 
                    title="Click to toggle status"
                >
                    <%= user.is_active ? '● ACTIVE' : '○ STANDBY' %>
                </button>
              </td>

              <td>
                <a href="/whitelist/<%= user.id %>/history" style="text-decoration: none; color: var(--text); border-bottom: 1px dashed var(--text-light); padding-bottom: 2px; transition: all 0.2s;" onmouseover="this.style.color='var(--primary)'; this.style.borderColor='var(--primary)';" onmouseout="this.style.color='var(--text)'; this.style.borderColor='var(--text-light)';">
                    <strong style="color: inherit;"><%= user.discord_username %></strong>
                </a>
              </td>

              <td>
                <div style="font-size: 0.9rem; font-weight: 600; color: <%= luckColor %>;">
                    <%= user.win_count %> / <%= user.spin_count %> 
                    <small style="font-weight: 400; opacity: 0.8; margin-left: 0.3rem;">(<%= winRate %>%)</small>
                </div>
                <div style="width: 100%; height: 4px; background: #eee; border-radius: 2px; margin-top: 4px; overflow: hidden;">
                    <div style="width: <%= winRate %>%; height: 100%; background: <%= luckColor %>;"></div>
                </div>
              </td>
              <td>
                <code style="background: #f1f5f9; padding: 0.2rem 0.4rem; border-radius: 4px; font-size: 0.85rem;"><%= user.discord_user_id %></code>
              </td>
              <td style="text-align: right;">
                <form action="/whitelist/<%= user.id %>/delete" method="POST" class="ajax-delete" data-confirm="Confirm permanent deletion?" style="display:inline;">
                  <button type="submit" class="btn btn-secondary" style="color: var(--danger); font-size: 0.8rem; padding: 0.3rem 0.6rem;">Delete</button>
                </form>
              </td>
            </tr>
          <% } %>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<script>
    const whitelistData = <%- JSON.stringify(whitelist) %>;
    let selectedMembers = [...whitelistData]; // เริ่มต้นให้เลือกทุกคน

    const canvas = document.getElementById('wheel-canvas');
    const ctx = canvas.getContext('2d');
    const pointer = document.querySelector('.wheel-pointer');
    const resultDiv = document.getElementById('lottery-result');
    const spinBtn = document.getElementById('spin-btn');
    const timeline = document.getElementById('winners-timeline');
    const statusText = document.getElementById('lottery-status');
    const finalActions = document.getElementById('final-actions');
    const hiddenInputs = document.getElementById('winners-hidden-input');

    let currentRotation = 0;
    let winnersList = [];
    let lastSpinParticipants = []; // จำรายชื่อคนที่สุ่มจริงๆ

    function drawWheel() {
        if (!selectedMembers.length) {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            ctx.fillStyle = "#ccc";
            ctx.textAlign = "center";
            ctx.fillText("Please select names below", canvas.width/2, canvas.height/2);
            return;
        }
        const segments = selectedMembers.length;
        const anglePerSegment = (Math.PI * 2) / segments;
        const centerX = canvas.width / 2;
        const centerY = canvas.height / 2;
        const radius = centerX - 15;

        ctx.clearRect(0, 0, canvas.width, canvas.height);

        for (let i = 0; i < segments; i++) {
            const startAngle = i * anglePerSegment;
            const endAngle = (i + 1) * anglePerSegment;
            
            ctx.beginPath();
            ctx.moveTo(centerX, centerY);
            ctx.arc(centerX, centerY, radius, startAngle, endAngle);
            
            // ใช้ index จาก whitelistData เดิม เพื่อให้สีไม่เปลี่ยนไปมาตอนคนถูกลบออก
            const originalIndex = whitelistData.findIndex(u => u.id === selectedMembers[i].id);
            const totalOriginal = whitelistData.length || 1;
            ctx.fillStyle = `hsl(${(originalIndex * 360/totalOriginal) % 360}, 65%, ${originalIndex % 2 === 0 ? '60%' : '70%'})`;
            
            ctx.fill();
            ctx.strokeStyle = "rgba(255,255,255,0.3)";
            ctx.lineWidth = 1;
            ctx.stroke();

            // Text
            ctx.save();
            ctx.translate(centerX, centerY);
            ctx.rotate(startAngle + anglePerSegment / 2);
            ctx.textAlign = "right";
            ctx.fillStyle = "white";
            ctx.font = "bold 12px Inter";
            const name = selectedMembers[i].discord_username;
            ctx.fillText(name.length > 15 ? name.substring(0, 13) + '..' : name, radius - 20, 5);
            ctx.restore();
        }

        ctx.beginPath();
        ctx.arc(centerX, centerY, 30, 0, Math.PI * 2);
        ctx.fillStyle = "white";
        ctx.fill();
        ctx.strokeStyle = "var(--primary)";
        ctx.lineWidth = 4;
        ctx.stroke();
    }

    drawWheel();

    function updateWheelFromSelection() {
        const checkboxes = document.querySelectorAll('.participant-checkbox:checked');
        const selectedIds = Array.from(checkboxes).map(cb => parseInt(cb.value));
        selectedMembers = whitelistData.filter(m => selectedIds.includes(m.id));
        
        // อัปเดตตัวเลข Max ในช่อง Input
        document.getElementById('lottery-count').max = selectedMembers.length;
        if (parseInt(document.getElementById('lottery-count').value) > selectedMembers.length) {
            document.getElementById('lottery-count').value = selectedMembers.length;
        }

        drawWheel();
    }

    function toggleSelectAll(cb) {
        const checkboxes = document.querySelectorAll('.participant-checkbox');
        checkboxes.forEach(c => c.checked = cb.checked);
        updateWheelFromSelection();
    }

    async function startLottery() {
        const count = parseInt(document.getElementById('lottery-count').value);
        if (!selectedMembers.length) return alert('Please select at least 1 person');
        if (count > selectedMembers.length) return alert('Count cannot exceed selected members');

        // จำรายชื่อคนเข้าวงล้อรอบนี้ไว้ เพื่อให้ตอนกดเซฟข้อมูลตรงกัน 100%
        lastSpinParticipants = [...selectedMembers];

        spinBtn.disabled = true;
        winnersList = [];
        timeline.innerHTML = '';
        finalActions.style.display = 'none';
        
        let availablePool = [...lastSpinParticipants];

        for (let i = 0; i < count; i++) {
            statusText.innerText = `🌀 Spinning winner ${i + 1} of ${count}...`;
            
            const winnerIdxInPool = Math.floor(Math.random() * availablePool.length);
            const winner = availablePool[winnerIdxInPool];
            
            // หาตำแหน่งใน selectedMembers สำหรับวาดวงล้อ
            const wheelIdx = selectedMembers.findIndex(u => u.id === winner.id);
            
            await spinTo(wheelIdx);
            
            // --- จังหวะที่ 1: นิ่งชี้เป้าบนวงล้อให้คนดูและลุ้นทัน 1.5 วินาที ---
            await new Promise(r => setTimeout(r, 1500));
            
            // เพิ่มรายชื่อเข้า Timeline ด้านขวา
            winnersList.push(winner);
            availablePool.splice(winnerIdxInPool, 1);
            addWinnerToTimeline(winner, i + 1);
            
            // --- จังหวะที่ 2: รอให้ชื่อโชว์เด่นอยู่บน Timeline อีก 1.5 วินาที เพื่อให้ฉลอง/อ่านชื่อทัน ---
            await new Promise(r => setTimeout(r, 1500));
            
            // ลบชื่อออกจากวงล้อทีหลัง เพื่อไม่ให้วงล้อขยับสั่นทันทีจนขัดจังหวะสายตา
            selectedMembers.splice(wheelIdx, 1);
            drawWheel();
            
            // หากมีคนต่อไปที่จะสุ่ม ให้เว้นจังหวะสั้นๆ (800ms) ก่อนจะหมุนต่อ
            if (i < count - 1) await new Promise(r => setTimeout(r, 800));
        }

        statusText.innerText = `✨ Successfully selected ${count} winners!`;
        showFinalActions();
    }

    function spinTo(index) {
        return new Promise((resolve) => {
            const segments = selectedMembers.length;
            const anglePerSegment = 360 / segments;
            
            // สุ่มว่ารอบนี้จะเป็นจังหวะลุ้นเป็นพิเศษตรงเส้นแบ่งหรือไม่ (40% และมีผู้เล่นมากกว่า 1 คน)
            const isSuspenseMode = segments > 1 && Math.random() < 0.4;
            
            let segmentTargetAngle;
            if (isSuspenseMode) {
                // โหมดลุ้นพิเศษ: หยุดใกล้ขอบทางเข้าของช่องผู้ชนะ (2 - 4 องศา)
                const closeToBorderOffset = Math.random() * 2 + 2;
                segmentTargetAngle = ((index + 1) * anglePerSegment) - closeToBorderOffset;
            } else {
                // โหมดปกติ: สุ่มตำแหน่งกระจายทั่วช่อง (15% - 85%)
                const randomOffset = (Math.random() * 0.7 + 0.15) * anglePerSegment;
                segmentTargetAngle = (index * anglePerSegment) + randomOffset;
            }
            
            const targetRotation = 360 - segmentTargetAngle;
            const randomSpins = Math.floor(Math.random() * 5) + 8;
            const extraSpins = randomSpins * 360;
            
            // ตำแหน่งที่จะหยุดจริง (final resting position)
            let nextRotation = currentRotation + extraSpins + (targetRotation - (currentRotation % 360));
            if (nextRotation < currentRotation) nextRotation += 360;
            
            const durationMs = 5000 + (randomSpins * 350);

            if (isSuspenseMode) {
                // --- โหมดลุ้นขอบ: หมุนจังหวะเดียวไหลเข้าช่องผู้ชนะ ไม่มี overshoot ---
                canvas.style.transition = `transform ${durationMs}ms cubic-bezier(0.1, 0.85, 0.1, 1)`;
                canvas.style.transform = `rotate(${nextRotation}deg)`;
                currentRotation = nextRotation;
                setTimeout(resolve, durationMs + 100);
            } else {
                // --- โหมดปกติ: ล้อหมุนเลยตำแหน่งผู้ชนะไปนิดนึง (5 - 8 องศา ในทิศหมุนเดิม)
                //     แล้วแรงหนืดค่อยๆ ดึงกลับมาหยุดนิ่งที่ผู้ชนะ ---
                const overshootDeg = Math.random() * 3 + 5; // 5 - 8 องศา เลยผ่านไป
                const overshootRotation = nextRotation + overshootDeg;
                
                // Stage 1: หมุนเลยผู้ชนะไปนิดนึง (ยังคงทิศทางเดิม ดูเป็นธรรมชาติ)
                canvas.style.transition = `transform ${durationMs}ms cubic-bezier(0.1, 0.85, 0.1, 1)`;
                canvas.style.transform = `rotate(${overshootRotation}deg)`;
                
                setTimeout(() => {
                    // Stage 2: แรงหนืดดึงกลับ — เริ่มขยับพร้อม momentum เหลืออยู่นิดหน่อย
                    // แล้วค่อยๆ ชะลอจนหยุดที่ผู้ชนะ (ease-out คือ ไม่มีการเร่งซ้ำ, ค่อยๆ ช้าลง)
                    const returnDuration = 450;
                    canvas.style.transition = `transform ${returnDuration}ms cubic-bezier(0.25, 0, 0.5, 1)`;
                    canvas.style.transform = `rotate(${nextRotation}deg)`;
                    currentRotation = nextRotation;
                    setTimeout(resolve, returnDuration + 50);
                }, durationMs);
            }
        });
    }

    function addWinnerToTimeline(user, rank) {
        const item = document.createElement('div');
        item.className = 'winner-item winner-card';
        item.style.padding = '0.75rem';
        item.style.marginBottom = '0.5rem';
        item.style.borderLeft = '4px solid var(--primary)';
        item.innerHTML = `
            <div style="display:flex; justify-content:space-between; align-items:center;">
                <div style="display:flex; gap:1rem; align-items:center;">
                    <span style="background:var(--primary); color:white; width:24px; height:24px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:0.75rem; font-weight:bold;">${rank}</span>
                    <strong style="font-size:1.1rem;">${user.discord_username}</strong>
                </div>
                <span style="font-size:1.2rem;">🏆</span>
            </div>
        `;
        timeline.prepend(item); // Newest on top
    }

    function showFinalActions() {
        spinBtn.disabled = false;
        finalActions.style.display = 'block';
        hiddenInputs.innerHTML = winnersList.map(w => `
            <input type="hidden" name="winners[]" value="${w.id}">
        `).join('');
    }

    function resetLottery() {
        // Clear winners
        winnersList = [];
        timeline.innerHTML = '<div style="text-align: center; color: #94a3b8; margin-top: 5rem;">Winners list will appear here...</div>';
        
        // รีเซ็ตสถานะ
        statusText.innerText = 'Waiting to start...';
        
        // ซ่อนปุ่มต่างๆ
        finalActions.style.display = 'none';
        
        // เปิดปุ่มสุ่มใหม่
        spinBtn.disabled = false;
        
        // ดึงรายชื่อกลับมาวาดวงล้อใหม่ให้เต็มเหมือนตอนแรก
        updateWheelFromSelection();
    }

    async function applyLottery(e) {
        if (e) e.preventDefault();
        
        const btn = document.getElementById('confirm-winners-btn');
        const originalText = btn.innerHTML;
        btn.disabled = true;
        btn.innerHTML = '⌛ Saving results...';

        try {
            // ใช้รายชื่อที่จำไว้ตอนสุ่ม (lastSpinParticipants) แทนการดึงใหม่
            const payload = {
                winners: winnersList.map(w => w.id),
                participants: lastSpinParticipants.map(m => m.id)
            };

            const response = await fetch('/whitelist/lottery-apply', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            });

            if (response.ok) {
                // Success
                statusText.innerHTML = '✅ Winners saved successfully!';
                statusText.style.color = 'var(--success)';
                
                // รอสักครู่แล้วรีเซ็ตหน้าวงล้อ
                setTimeout(() => {
                    resetLottery();
                    statusText.style.color = 'var(--text-light)';
                    // เราอาจจะสั่ง reload เบาๆ เพื่ออัปเดตตัวเลข Win Count ในตาราง
                    // แต่ถ้าอยากให้เทพสุดๆ คือปล่อยไปแบบนี้ แล้วให้เค้ากดดูเอง
                    // ในที่นี้ผมจะให้ reload หลังจากบันทึกสำเร็จเพื่อให้ข้อมูลในตารางเป็นปัจจุบันครับ
                    // แต่ถ้าผู้ใช้ไม่อยากให้ refresh เลย ผมจะข้ามไปก่อน
                    window.location.reload(); 
                }, 1500);
            } else {
                throw new Error('บันทึกไม่สำเร็จ');
            }
        } catch (err) {
            console.error(err);
            alert('Error: ' + err.message);
            btn.disabled = false;
            btn.innerHTML = originalText;
        }
    }

    // --- AJAX Toggle Status (No Refresh) ---
    async function toggleStatus(id, currentStatus) {
        const btn = document.getElementById(`btn-status-${id}`);
        const row = document.getElementById(`row-${id}`);
        
        // เราจะแกล้งเปลี่ยน UI ทันทีล่วงหน้าเลยครับ (Optimistic Update)
        const newStatus = !currentStatus;
        updateToggleUI(id, newStatus);

        try {
            const response = await fetch(`/whitelist/${id}/toggle`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ is_active: newStatus.toString() })
            });

            if (!response.ok) throw new Error('Toggle failed');
            
            // อัปเดตผูกมัดค่าใหม่ไว้กดครั้งต่อไป
            btn.onclick = () => toggleStatus(id, newStatus);
            
        } catch (err) {
            console.error(err);
            alert('Error toggling status');
            // Revert
            updateToggleUI(id, currentStatus);
        }
    }

    function updateToggleUI(id, isActive) {
        const btn = document.getElementById(`btn-status-${id}`);
        const row = document.getElementById(`row-${id}`);

        if (isActive) {
            btn.className = 'badge badge-success';
            btn.innerText = '● ACTIVE';
            row.style.opacity = '1';
            row.style.backgroundColor = 'transparent';
        } else {
            btn.className = 'badge badge-gray';
            btn.innerText = '○ STANDBY';
            row.style.opacity = '0.6';
            row.style.backgroundColor = '#f8fafc';
        }
    }
</script>



