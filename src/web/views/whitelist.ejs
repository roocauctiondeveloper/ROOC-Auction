<link rel="stylesheet" href="/css/lottery.css">

<div class="flex space-between items-center" style="margin-bottom: 2rem;">
  <h1>Whitelist & Selection</h1>
</div>

<div class="card" style="border-left: 4px solid var(--primary);">
  <h3 style="margin-bottom: 1.5rem;">Add New Member</h3>
  <p style="color: var(--text-light); margin-bottom: 1rem; font-size: 0.9rem;">
    💡 ใส่เพียง <b>Discord User ID</b> ระบบจะดึงชื่อมาให้โดยอัตโนมัติครับ
  </p>
  <form action="/whitelist" method="POST" style="display: flex; gap: 1rem; align-items: flex-end;">
    <div class="form-group" style="margin-bottom: 0; flex-grow: 1;">
      <label for="discord_user_id">Discord User ID</label>
      <input type="text" id="discord_user_id" name="discord_user_id" required placeholder="ตัวอย่าง: 123456789012345678">
    </div>
    <button class="btn btn-primary" type="submit">Add User</button>
  </form>
</div>

<!-- 🎡 Spin Wheel Section -->
<div class="card lottery-section" style="background: linear-gradient(to bottom, #ffffff, #f8fafc);">
    <div class="flex-desktop flex space-between items-center" style="margin-bottom: 2rem;">
        <div>
            <h3 style="margin: 0; font-family: 'Outfit';">🎡 Whitelist Lottery (Gacha Mode)</h3>
            <p style="color: var(--text-light); font-size: 0.85rem;">ระบบจะสุ่มชื่อทีละคนเพื่อความตื่นเต้นครับ!</p>
        </div>
        <div class="lottery-controls">
            <div style="background: #f1f5f9; padding: 0.5rem 1rem; border-radius: 12px; border: 1px solid #e2e8f0; display: flex; align-items: center; gap: 1rem;">
                <span style="font-weight: 600; font-size: 0.9rem;">จำนวนผู้ชนะ:</span>
                <input type="number" id="lottery-count" value="1" min="1" max="<%= whitelist.length %>" style="width: 60px; border:none; background:transparent; font-weight: 700; color: var(--primary); font-size: 1.1rem;">
                <button class="btn btn-primary" onclick="startLottery()" id="spin-btn" style="border-radius: 10px; box-shadow: 0 4px 6px rgba(99, 102, 241, 0.3);">🔥 เริ่มสุ่ม!</button>
            </div>
        </div>
    </div>

    <div class="lottery-layout" style="display: grid; grid-template-columns: 1.2fr 0.8fr; gap: 2rem; align-items: start;">
        <!-- Left: The Wheel -->
        <div class="wheel-container" style="background: transparent; padding: 0; position: relative; margin: 0;">
            <canvas id="wheel-canvas" width="450" height="450" style="width: 100%; max-width: 450px;"></canvas>
            <div class="wheel-pointer" style="right: -10px;"></div>
        </div>

        <!-- Right: Winner List / Timeline -->
        <div class="results-container">
            <div id="lottery-status" style="margin-bottom: 1rem; font-weight: 700; color: var(--text-light); text-transform: uppercase; font-size: 0.8rem; letter-spacing: 0.1em;">
                Waiting to start...
            </div>
            <div id="winners-timeline" style="display: flex; flex-direction: column; gap: 0.75rem; min-height: 300px; padding: 1rem; background: #f8fafc; border-radius: var(--radius); border: 2px dashed #e2e8f0;">
                <!-- Winners appear here one by one -->
                <div style="text-align: center; color: #94a3b8; margin-top: 5rem;">รายชื่อผู้โชคดีจะปรากฏที่นี่...</div>
            </div>

            <!-- Final Action (hidden until end) -->
            <div id="final-actions" style="display: none; margin-top: 1.5rem; animation: celebrate 0.5s ease-out;">
                <form action="/whitelist/lottery-apply" method="POST">
                    <div id="winners-hidden-input"></div>
                    <button type="submit" class="btn btn-primary" style="width: 100%; padding: 1rem; font-size: 1.1rem;">✅ ยืนยันผลการสุ่มทั้งหมด</button>
                </form>
                <button onclick="window.location.reload()" class="btn btn-secondary" style="width: 100%; margin-top: 0.5rem;">ยกเลิกและสุ่มใหม่</button>
            </div>
        </div>
    </div>
</div>

<div class="card">
  <div class="flex space-between items-center" style="margin-bottom: 1.5rem;">
    <h3 style="margin: 0;">Members Management (<%= whitelist.length %>)</h3>
  </div>
  
  <div class="table-responsive">
    <table>
      <thead>
        <tr>
          <th>Status</th>
          <th>User Info</th>
          <th>Discord ID</th>
          <th style="text-align: right;">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% if (whitelist.length === 0) { %>
          <tr>
            <td colspan="4" style="text-align: center; padding: 3rem 1rem; color: var(--text-light);">No users found.</td>
          </tr>
        <% } else { %>
          <% for(let user of whitelist) { %>
            <tr style="<%= user.is_active ? '' : 'opacity: 0.6; background-color: #f8fafc;' %>">
              <td style="width: 120px;">
                <form action="/whitelist/<%= user.id %>/toggle" method="POST">
                    <input type="hidden" name="is_active" value="<%= !user.is_active %>">
                    <button type="submit" class="badge <%= user.is_active ? 'badge-success' : 'badge-gray' %>" style="border:none; cursor:pointer;" title="คลิกเพื่อสลับสถานะ">
                        <%= user.is_active ? '● ACTIVE' : '○ STANDBY' %>
                    </button>
                </form>
              </td>
              <td>
                <div style="font-weight: 700; color: var(--text);"><%= user.discord_username %></div>
              </td>
              <td>
                <code style="background: #f1f5f9; padding: 0.2rem 0.4rem; border-radius: 4px; font-size: 0.85rem;"><%= user.discord_user_id %></code>
              </td>
              <td style="text-align: right;">
                <form action="/whitelist/<%= user.id %>/delete" method="POST" style="display:inline;" onsubmit="return confirm('ยืนยันลบถาวร?');">
                  <button type="submit" class="btn btn-secondary" style="color: var(--danger); font-size: 0.8rem; padding: 0.3rem 0.6rem;">Delete</button>
                </form>
              </td>
            </tr>
          <% } %>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<script>
    const whitelistData = <%- JSON.stringify(whitelist) %>;
    const canvas = document.getElementById('wheel-canvas');
    const ctx = canvas.getContext('2d');
    const timeline = document.getElementById('winners-timeline');
    const statusText = document.getElementById('lottery-status');
    const spinBtn = document.getElementById('spin-btn');
    const finalActions = document.getElementById('final-actions');
    const hiddenInputs = document.getElementById('winners-hidden-input');

    let currentRotation = 0;
    let winnersList = [];

    function drawWheel() {
        if (!whitelistData.length) return;
        const segments = whitelistData.length;
        const anglePerSegment = (Math.PI * 2) / segments;
        const centerX = canvas.width / 2;
        const centerY = canvas.height / 2;
        const radius = centerX - 15;

        ctx.clearRect(0, 0, canvas.width, canvas.height);

        for (let i = 0; i < segments; i++) {
            const startAngle = i * anglePerSegment;
            const endAngle = (i + 1) * anglePerSegment;
            
            ctx.beginPath();
            ctx.moveTo(centerX, centerY);
            ctx.arc(centerX, centerY, radius, startAngle, endAngle);
            ctx.fillStyle = `hsl(${(i * 360/segments) % 360}, 65%, ${i % 2 === 0 ? '60%' : '70%'})`;
            ctx.fill();
            ctx.strokeStyle = "rgba(255,255,255,0.3)";
            ctx.lineWidth = 1;
            ctx.stroke();

            // Text
            ctx.save();
            ctx.translate(centerX, centerY);
            ctx.rotate(startAngle + anglePerSegment / 2);
            ctx.textAlign = "right";
            ctx.fillStyle = "white";
            ctx.font = "bold 12px Inter";
            const name = whitelistData[i].discord_username;
            ctx.fillText(name.length > 15 ? name.substring(0, 13) + '..' : name, radius - 20, 5);
            ctx.restore();
        }

        // Stylized Center
        ctx.beginPath();
        ctx.arc(centerX, centerY, 30, 0, Math.PI * 2);
        ctx.fillStyle = "white";
        ctx.fill();
        ctx.strokeStyle = "var(--primary)";
        ctx.lineWidth = 4;
        ctx.stroke();
    }

    drawWheel();

    async function startLottery() {
        const count = parseInt(document.getElementById('lottery-count').value);
        if (!whitelistData.length) return alert('ไม่มีรายชื่อครับ');
        if (count > whitelistData.length) return alert('จำนวนสุ่มต้องไม่เกินจำนวนคนทั้งหมด');

        spinBtn.disabled = true;
        winnersList = [];
        timeline.innerHTML = '';
        finalActions.style.display = 'none';
        
        let availablePool = [...whitelistData];

        for (let i = 0; i < count; i++) {
            statusText.innerText = `🌀 กำลังสุ่มคนที่ ${i + 1} จาก ${count}...`;
            
            // Pick a winner from pool
            const winnerIdxInPool = Math.floor(Math.random() * availablePool.length);
            const winner = availablePool[winnerIdxInPool];
            
            // Find its index in the ORIGINAL whitelistData for rotation calculation
            const originalIdx = whitelistData.findIndex(u => u.id === winner.id);
            
            await spinTo(originalIdx);
            
            // Add to winner list
            winnersList.push(winner);
            availablePool.splice(winnerIdxInPool, 1);
            
            addWinnerToTimeline(winner, i + 1);
            
            // Short pause between spins
            if (i < count - 1) await new Promise(r => setTimeout(r, 1000));
        }

        statusText.innerText = `✨ สุ่มครบ ${count} คนเรียบร้อยแล้ว!`;
        showFinalActions();
    }

    function spinTo(index) {
        return new Promise((resolve) => {
            const segments = whitelistData.length;
            const anglePerSegment = 360 / segments;
            
            // Calculate target angle to point at 0 degrees (right side)
            // The segment angle starts from 0, but we want the middle of it to land at 0 rotation.
            const segmentMiddleAngle = (index * anglePerSegment) + (anglePerSegment / 2);
            
            // We need to rotate 360 - segmentMiddleAngle to bring it to the pointer
            const targetRotation = 360 - segmentMiddleAngle;
            
            // Add multiple full spins for effect
            const extraSpins = 3 * 360;
            currentRotation += extraSpins + (targetRotation - (currentRotation % 360));
            if (currentRotation < 0) currentRotation += 360; // Keep positive

            canvas.style.transform = `rotate(${currentRotation}deg)`;
            
            // Wait for transition to finish (matches CSS duration)
            setTimeout(resolve, 4000); 
        });
    }

    function addWinnerToTimeline(user, rank) {
        const item = document.createElement('div');
        item.className = 'winner-item winner-card';
        item.style.padding = '0.75rem';
        item.style.marginBottom = '0.5rem';
        item.style.borderLeft = '4px solid var(--primary)';
        item.innerHTML = `
            <div style="display:flex; justify-content:space-between; align-items:center;">
                <div style="display:flex; gap:1rem; align-items:center;">
                    <span style="background:var(--primary); color:white; width:24px; height:24px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:0.75rem; font-weight:bold;">${rank}</span>
                    <strong style="font-size:1.1rem;">${user.discord_username}</strong>
                </div>
                <span style="font-size:1.2rem;">🏆</span>
            </div>
        `;
        timeline.prepend(item); // Newest on top
    }

    function showFinalActions() {
        spinBtn.disabled = false;
        finalActions.style.display = 'block';
        hiddenInputs.innerHTML = winnersList.map(w => `
            <input type="hidden" name="winners[]" value="${w.id}">
        `).join('');
    }
</script>


