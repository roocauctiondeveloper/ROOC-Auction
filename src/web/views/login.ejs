<div style="height: 100vh; display: flex; align-items: center; justify-content: center; background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%); margin: -2rem;">
  <div class="card" style="max-width: 440px; width: 90%; text-align: center; padding: 3.5rem 2.5rem; border-radius: 20px; box-shadow: 0 20px 50px rgba(0,0,0,0.1);">
    <div style="font-size: 3.5rem; margin-bottom: 1.5rem;">💎</div>
    <h1 style="margin-bottom: 0.5rem; font-family: 'Outfit', sans-serif; font-size: 2rem; letter-spacing: -0.02em;">Admin Dashboard</h1>
    <p style="margin-bottom: 2.5rem; color: var(--text-light); font-weight: 500;">เข้าสู่ระบบเพื่อจัดการรอบประมูลและรายการสินค้า</p>
    
    <% if (typeof error_msg !== 'undefined' && error_msg) { %>
      <div style="background-color: #fee2e2; color: #b91c1c; padding: 1rem; border-radius: 12px; margin-bottom: 1.5rem; font-size: 0.95rem; font-weight: 600; border: 1px solid #fecaca;">
        ⚠️ <%= error_msg %>
      </div>
    <% } %>
    
    <a href="/auth/discord" class="btn" style="
      background-color: #5865F2;
      color: white;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 12px;
      width: 100%;
      padding: 1rem;
      border-radius: 12px;
      font-weight: 600;
      font-size: 1.1rem;
      transition: all 0.2s;
      box-shadow: 0 4px 15px rgba(88, 101, 242, 0.3);
    " onmouseover="this.style.backgroundColor='#4752c4'; this.style.transform='translateY(-2px)'" 
       onmouseout="this.style.backgroundColor='#5865F2'; this.style.transform='translateY(0)'">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
        <path d="M20.317 4.3698a19.7913 19.7913 0 00-4.8851-1.5152.0741.0741 0 00-.0785.0371c-.211.3753-.4447.8648-.6083 1.2495-1.8447-.2758-3.68-.2758-5.4876 0-.1636-.3933-.4058-.8742-.6177-1.2495a.077.077 0 00-.0785-.037 19.7363 19.7363 0 00-4.8852 1.515.0699.0699 0 00-.0321.0277C.5334 9.0458-.319 13.5799.0992 18.0578a.0824.0824 0 00.0312.0561c2.0528 1.5076 4.0413 2.4228 5.9929 3.0294a.0777.0777 0 00.0842-.0276c.4616-.6304.8731-1.2952 1.226-1.9942a.076.076 0 00-.0416-.1057c-.6528-.2476-1.2743-.5495-1.8722-.8923a.077.077 0 01-.0076-.1277c.1258-.0943.2517-.1923.3718-.2914a.0743.0743 0 01.0776-.0105c3.9278 1.7933 8.18 1.7933 12.0614 0a.0739.0739 0 01.0785.0095c.1202.099.246.1971.3728.2914a.077.077 0 01-.0066.1277 12.2986 12.2986 0 01-1.873.8914.0766.0766 0 00-.0407.1067c.3604.698.7719 1.3628 1.225 1.9932a.076.076 0 00.0842.0286c1.961-.6067 3.9495-1.5219 6.0023-3.0294a.077.077 0 00.0313-.0552c.5004-5.177-.8382-9.6739-3.5485-13.6604a.061.061 0 00-.0312-.0286zM8.02 15.3312c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9555-2.4189 2.157-2.4189 1.2108 0 2.1757 1.0951 2.1568 2.419 0 1.3332-.9555 2.4189-2.1569 2.4189zm7.9748 0c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9554-2.4189 2.1569-2.4189 1.2108 0 2.1757 1.0951 2.1568 2.419 0 1.3332-.946 2.4189-2.1568 2.4189z"/>
      </svg>
      Login with Discord
    </a>
    
    <div style="margin-top: 2rem; font-size: 0.85rem; color: var(--text-light);">
      &copy; <%= new Date().getFullYear() %> ROOC Auction Admin
    </div>
  </div>
</div>
