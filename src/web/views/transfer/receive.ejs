<!-- Load QRCode CDN library in browser -->
<script src="https://cdn.jsdelivr.net/npm/qrcode@1.4.4/build/qrcode.min.js"></script>

<style>
  @keyframes modalFadeIn {
    from { opacity: 0; transform: scale(0.95); }
    to { opacity: 1; transform: scale(1); }
  }
  @keyframes gradientBorder {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }
  @keyframes glowSpecial {
    0% { box-shadow: 0 0 10px rgba(236, 72, 153, 0.4), 0 0 18px rgba(99, 102, 241, 0.2); }
    50% { box-shadow: 0 0 20px rgba(236, 72, 153, 0.8), 0 0 32px rgba(99, 102, 241, 0.5); }
    100% { box-shadow: 0 0 10px rgba(236, 72, 153, 0.4), 0 0 18px rgba(99, 102, 241, 0.2); }
  }
  .special-sender-card {
    border: 3px solid transparent !important;
    background-image: linear-gradient(white, white), linear-gradient(135deg, #ff007f, #7f00ff, #00f0ff, #ff007f) !important;
    background-origin: border-box !important;
    background-clip: content-box, border-box !important;
    background-size: 300% 300% !important;
    animation: gradientBorder 4s ease infinite, glowSpecial 3s ease-in-out infinite !important;
  }
</style>

<div style="display: flex; flex-direction: column; gap: 2rem;">
  <!-- Section 1: Pending Inbox -->
  <div class="card">
    <h2 style="color: var(--primary); margin-bottom: 0.5rem; display: flex; align-items: center; gap: 0.5rem;">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
      กล่องรับโอนสิทธิ์จอง (Incoming Offers)
    </h2>
    <p style="color: var(--text-light); margin-bottom: 1.5rem; font-size: 0.95rem;">
      รายการจองไอเทมที่ผู้เล่นท่านอื่นประสงค์จะโอนสิทธิ์ให้กับคุณ เลือกดีลที่ต้องการกรอกราคาและโอนเงินชำระ
    </p>

    <%
      const uniqueTypes = new Set(['Album', 'Illution Box', 'Light-Dark', 'Time-Space']);
      pendingTransfers.forEach(t => {
        (t.items || []).forEach(item => {
          uniqueTypes.add(item.item_type);
        });
      });
      const typesArray = Array.from(uniqueTypes);
      const typeDisplayMap = {
        'Album': '📒 Album',
        'Illution Box': '🧩 Box',
        'Feather': '🪶 Feather',
        'Card': '🎴 Card',
        'Book': '📖 Book',
        'Light-Dark': '🤍 LD',
        'Time-Space': '❤️ TS'
      };
    %>
    <!-- Global Price Configuration (Locked outside) -->
    <div style="background: #f0fdf4; border: 1px solid #bbf7d0; border-radius: 8px; padding: 0.75rem 1rem; margin-bottom: 1.5rem; max-width: 650px;">
      <div style="font-size: 0.85rem; font-weight: 700; color: #166534; margin-bottom: 0.6rem; display: flex; align-items: center; gap: 4px;">
        <span>🧮 กำหนดราคาต่อชิ้นตามประเภท (คำนวณราคายอดรวมอัตโนมัติ)</span>
      </div>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(115px, 1fr)); gap: 0.75rem;">
        <% typesArray.forEach(type => { 
             const display = typeDisplayMap[type] || type;
        %>
          <div style="display: flex; align-items: center; gap: 4px;">
            <span style="font-size: 0.75rem; color: #166534; font-weight: 600; min-width: 55px;"><%= display %>:</span>
            <input type="number" class="price-input-dynamic" data-type="<%= type %>" placeholder="0" min="0" style="padding: 0.25rem; font-size: 0.8rem; height: auto; border: 1px solid #cbd5e1; border-radius: 4px; width: 65px;" oninput="saveAndRecalculatePrices()">
          </div>
        <% }) %>
      </div>
    </div>

    <div id="pending-inbox-container">
    <% if (pendingTransfers.length === 0) { %>
      <p style="color: var(--text-light); text-align: center; padding: 3rem 0; font-size: 0.95rem;">
        ไม่มีข้อเสนอโอนสิทธิ์ส่งถึงคุณในขณะนี้
      </p>
    <% } else { %>
      <%
        const specialUserIds = new Set(['295747827517227009', '1496001204549976114']);
        pendingTransfers.sort((a, b) => {
          const aSpecial = specialUserIds.has(a.sender_id) ? 1 : 0;
          const bSpecial = specialUserIds.has(b.sender_id) ? 1 : 0;
          return bSpecial - aSpecial;
        });
      %>
      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 1.5rem; margin-bottom: 2rem;">
        <% pendingTransfers.forEach(transfer => { %>
          <% const isSpecialUser = specialUserIds.has(transfer.sender_id); %>
          <div class="<%= isSpecialUser ? 'special-sender-card' : '' %>" style="background: white; border: 1px solid #e2e8f0; border-radius: 12px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05), 0 2px 4px -1px rgba(0,0,0,0.02); display: flex; flex-direction: column; overflow: hidden; transition: transform 0.2s, box-shadow 0.2s;" onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='0 10px 15px -3px rgba(0, 0, 0, 0.08)'" onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 4px 6px -1px rgba(0,0,0,0.05)'">
            
            <!-- Card Header: Sender Info -->
            <div style="background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%); padding: 1rem; border-bottom: 1px solid #e2e8f0; display: flex; align-items: center; justify-content: space-between;">
              <div style="display: flex; align-items: center; gap: 0.5rem;">
                <div style="background: <%= isSpecialUser ? 'linear-gradient(135deg, #ffd700, #ff8c00)' : 'var(--primary)' %>; color: white; width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 0.9rem; <%= isSpecialUser ? 'box-shadow: 0 0 8px rgba(255, 215, 0, 0.8);' : '' %>">
                  <%= transfer.sender_name.charAt(0).toUpperCase() %>
                </div>
                <div>
                  <div style="font-size: 0.75rem; color: var(--text-light); font-weight: 500;">ผู้เสนอโอน (Sender)</div>
                  <div style="font-size: 0.95rem; font-weight: 700; color: #0f172a; display: flex; align-items: center; gap: 4px;">
                    <%= transfer.sender_name %>
                    <% if (isSpecialUser) { %>
                      <span style="font-size: 0.95rem;" title="👑 ผู้เสนอโอนสุดพิเศษ">👑</span>
                    <% } %>
                  </div>
                </div>
              </div>
              <div style="display: flex; flex-direction: column; align-items: flex-end; gap: 4px;">
                <span class="badge badge-blue" style="font-size: 0.75rem; font-weight: 600; padding: 0.25rem 0.5rem; border-radius: 6px;">
                  รอคุณตอบรับ
                </span>
                <!-- Dynamic Total Price Badge -->
                <div style="display: none; font-size: 0.72rem; font-weight: 700; color: #166534; background: #ecfdf5; border: 1px solid #bbf7d0; padding: 0.15rem 0.35rem; border-radius: 6px; align-items: center; gap: 2px;" class="card-total-price-box" data-items="<%= JSON.stringify(transfer.items) %>">
                  <span>💰</span> <span class="card-total-price-value">-</span>
                </div>
              </div>
            </div>

            <!-- Card Body: Items List & Payment Options -->
            <div style="padding: 1.25rem; flex: 1; display: flex; flex-direction: column; gap: 1rem;">
              
              <!-- Items section -->
              <div>
                <div style="font-size: 0.75rem; color: var(--text-light); font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.5rem;">
                  📦 ไอเทมที่เสนอโอนให้คุณ (<%= transfer.items.length %> ชิ้น):
                </div>
                <div style="display: flex; gap: 0.5rem; flex-wrap: wrap; max-height: 150px; overflow-y: auto; background: #f8fafc; padding: 0.75rem; border-radius: 8px; border: 1px solid #e2e8f0;">
                  <% (transfer.compactSummary || []).forEach(summaryLine => { %>
                    <span style="background-color: #f1f5f9; color: #1e293b; border: 1px solid #cbd5e1; font-size: 0.8rem; padding: 0.3rem 0.6rem; border-radius: 6px; font-weight: 700; display: inline-flex; align-items: center; gap: 0.25rem; white-space: nowrap;">
                      <%= summaryLine %>
                    </span>
                  <% }) %>
                </div>
              </div>

              <!-- Payment Channels section -->
              <div>
                <div style="font-size: 0.75rem; color: var(--text-light); font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.5rem;">
                  💵 ช่องทางชำระเงินของดีลนี้:
                </div>
                <div style="display: flex; gap: 0.4rem; flex-wrap: wrap;">
                  <% if (transfer.bank_name && transfer.bank_account_number) { %>
                    <span class="badge" style="background-color: #eff6ff; color: #1e40af; border: 1px solid #bfdbfe; font-size: 0.75rem; padding: 0.25rem 0.5rem; display: inline-flex; align-items: center; gap: 0.25rem;">🏛️ บัญชีธนาคาร</span>
                  <% } %>
                  <% if (transfer.promptpay_id) { %>
                    <span class="badge" style="background-color: #ecfdf5; color: #065f46; border: 1px solid #a7f3d0; font-size: 0.75rem; padding: 0.25rem 0.5rem; display: inline-flex; align-items: center; gap: 0.25rem;">💳 PromptPay</span>
                  <% } %>
                  <% if (transfer.payment_qr_url) { %>
                    <span class="badge" style="background-color: #f3e8ff; color: #6b21a8; border: 1px solid #e9d5ff; font-size: 0.75rem; padding: 0.25rem 0.5rem; display: inline-flex; align-items: center; gap: 0.25rem;">🖼️ QR Code</span>
                  <% } %>
                </div>
              </div>
            </div>

            <!-- Card Footer: Action Button -->
            <div style="padding: 0 1.25rem 1.25rem 1.25rem;">
              <button class="btn btn-primary" style="width: 100%; font-weight: 600; display: flex; align-items: center; justify-content: center; gap: 0.4rem; padding: 0.6rem;" onclick="showClaimDetails(<%= JSON.stringify(transfer) %>)">
                💸 จ่ายเงิน & รับสิทธิ์นี้
              </button>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
    </div>
  </div>

  <!-- Section 2: Details view dynamically populated (Modal Overlay) -->
  <div id="claim-modal-overlay" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(15, 23, 42, 0.6); backdrop-filter: blur(4px); z-index: 9999; align-items: center; justify-content: center; padding: 1rem;">
    <div id="claim-details-card" class="card" style="width: 100%; max-width: 1100px; max-height: 90vh; overflow-y: auto; margin: 0; border: 2px solid var(--primary); box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.15); animation: modalFadeIn 0.2s ease-out;">
      <h2 style="color: #0f172a; margin-bottom: 1.5rem; display: flex; align-items: center; justify-content: space-between;">
        <span style="display: flex; align-items: center; gap: 0.5rem;">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2" ry="2"></rect><line x1="12" y1="4" x2="12" y2="20"></line><line x1="2" y1="12" x2="22" y2="12"></line></svg>
          ขั้นตอนการชำระเงินและโอนสิทธิ์
        </span>
        <button class="btn btn-secondary" style="padding: 0.4rem 0.8rem; font-size: 0.85rem;" onclick="closeClaimDetails()">ปิดหน้าต่าง</button>
      </h2>

      <div class="flex-desktop" style="display: flex; gap: 2rem;">
        <!-- Left side: Payment Info -->
        <div style="flex: 1;">
          <h3 style="font-size: 1.1rem; color: var(--primary); margin-bottom: 1rem;">ช่องทางชำระเงินของผู้ส่ง</h3>
          
          <!-- Bank Transfer Details Container -->
          <div id="details-bank" style="display: none; border: 1px solid #e2e8f0; border-radius: 8px; padding: 1rem; background: #f8fafc; margin-bottom: 1rem;">
            <div style="font-size: 0.8rem; text-transform: uppercase; color: var(--text-light); font-weight: 600; letter-spacing: 0.05em; margin-bottom: 0.5rem;">ช่องทาง: โอนเข้าบัญชีธนาคาร</div>
            <div style="font-weight: 700; font-size: 1.1rem; color: #0f172a;" id="details-bank-name">ธนาคาร</div>
            <div style="margin: 0.5rem 0;">
              <span style="font-size: 1.25rem; font-family: monospace; font-weight: 700; color: var(--primary);" id="details-bank-acc">123-4-56789-0</span>
              <button class="btn btn-secondary" style="padding: 0.25rem 0.5rem; font-size: 0.75rem; display: inline-flex; vertical-align: middle; margin-left: 0.5rem;" onclick="copyToClipboard('details-bank-acc')">📋 คัดลอกเลขบัญชี</button>
            </div>
            <div style="font-size: 0.95rem; color: var(--text);">ชื่อบัญชี: <strong id="details-bank-holder">สมชาย</strong></div>
          </div>

          <!-- Static QR Code Container -->
          <div id="details-qr" style="display: none; border: 1px solid #e2e8f0; border-radius: 8px; padding: 1rem; background: #f8fafc; text-align: center; margin-bottom: 1rem;">
            <div style="font-size: 0.8rem; text-transform: uppercase; color: var(--text-light); font-weight: 600; letter-spacing: 0.05em; margin-bottom: 0.5rem; text-align: left;">ช่องทาง: สแกน QR Code ส่วนตัว</div>
            <img id="details-qr-img" src="" alt="Payment QR Code" style="max-width: 250px; width: 100%; border-radius: 8px; box-shadow: var(--shadow); margin-top: 0.5rem;">
            <div style="margin-top: 0.75rem;">
              <a id="details-qr-download" href="" download class="btn btn-secondary" style="padding: 0.4rem 0.8rem; font-size: 0.8rem; display: inline-flex; width: auto;">💾 บันทึกรูปภาพ QR</a>
            </div>
          </div>

          <!-- PromptPay Generator Container -->
          <div id="details-promptpay" style="display: none; border: 1px solid #e2e8f0; border-radius: 8px; padding: 1rem; background: #f8fafc; text-align: center; margin-bottom: 1rem;">
            <div style="font-size: 0.8rem; text-transform: uppercase; color: var(--text-light); font-weight: 600; letter-spacing: 0.05em; margin-bottom: 0.5rem; text-align: left;">ช่องทาง: เจน PromptPay QR Code อัตโนมัติ</div>
            <div style="font-size: 0.95rem; color: var(--text); text-align: left; margin-bottom: 0.5rem;">
              เบอร์ PromptPay: <strong id="details-pp-id">0812345678</strong><br>
              ชื่อบัญชี Recheck: <strong id="details-pp-name">สมชาย</strong>
            </div>
            
            <div style="background: white; padding: 1rem; border-radius: 8px; display: inline-block; box-shadow: var(--shadow); margin-top: 0.5rem;">
              <canvas id="promptpay-qr-canvas"></canvas>
              <div style="font-family: 'Outfit', sans-serif; font-weight: 700; color: #000; margin-top: 0.5rem; font-size: 1.1rem;">PROMPT PAY</div>
            </div>
            <div style="margin-top: 0.75rem;">
              <button type="button" onclick="downloadPromptPayQR()" class="btn btn-secondary" style="padding: 0.4rem 0.8rem; font-size: 0.8rem; display: inline-flex; width: auto; align-items: center; gap: 4px;">
                💾 บันทึกรูปภาพ QR
              </button>
            </div>
            <p style="color: var(--text-light); font-size: 0.8rem; margin-top: 0.5rem;">
              *สแกนจ่ายเงินผ่านแอปธนาคารได้ทันที ยอดเงินตรงตามที่คุณกรอก*
            </p>
          </div>
        </div>

        <!-- Right side: Claim Form -->
        <div style="flex: 1; border-left: 1px solid #e2e8f0; padding-left: 2rem;">
          <h3 style="font-size: 1.1rem; color: #0f172a; margin-bottom: 1rem;">กรอกข้อมูลการโอนเงิน</h3>
          
          <form id="claim-form" action="" method="POST" enctype="multipart/form-data">
            <!-- Select items to claim (interactive checklist) -->
            <div class="form-group" style="margin-bottom: 1.5rem;">
              <label style="font-weight: 700; margin-bottom: 0.5rem; display: block; color: #0f172a;">เลือกไอเทมที่คุณต้องการรับโอนในรอบนี้:</label>
              
              <div style="display: flex; gap: 0.4rem; flex-wrap: wrap; margin-bottom: 0.6rem;">
                <button type="button" class="btn" style="padding: 0.2rem 0.5rem; font-size: 0.75rem; border: 1px solid #cbd5e1; color: #475569; background: white;" onclick="selectAllModalItems(true)">☑️ เลือกทั้งหมด</button>
                <button type="button" class="btn" style="padding: 0.2rem 0.5rem; font-size: 0.75rem; border: 1px solid #cbd5e1; color: #475569; background: white;" onclick="selectAllModalItems(false)">❌ ล้างทั้งหมด</button>
              </div>

              <!-- Grouped items container -->
              <div id="modal-items-container" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); gap: 0.75rem; background: #f8fafc; padding: 0.75rem; border-radius: 8px; border: 1px solid #e2e8f0; max-height: 250px; overflow-y: auto;">
              </div>
              
              <p style="color: var(--text-light); font-size: 0.75rem; margin-top: 0.5rem; line-height: 1.4;">
                *ของชิ้นที่คุณเอาเครื่องหมายถูกออก จะยังคงเป็นสิทธิ์การจองของผู้ส่งตามเดิม
              </p>
            </div>
            <div class="form-group">
              <label for="amount">ยอดเงินโอนจริงที่ตกลงไว้ (บาท):</label>
              <input type="number" name="amount" id="amount" placeholder="เช่น 150" step="0.01" min="0.01" required>
              <p style="color: var(--text-light); font-size: 0.8rem; margin-top: 0.3rem;">
                *ยอดเงินนี้จะถูกนำมาคำนวณ PromptPay QR ด้านซ้าย และส่งไปให้ผู้ส่งตรวจสอบสลิป
              </p>
            </div>

            <div class="form-group" style="margin-top: 1.5rem;">
              <label for="slip">แนบรูปภาพสลิปโอนเงิน:</label>
              <input type="file" name="slip" id="slip" accept="image/*" required>
              <p style="color: var(--text-light); font-size: 0.8rem; margin-top: 0.3rem;">
                *กรุณาแนบรูปภาพหลักฐานสลิปโอนเงินจริงเท่านั้น (ไม่จำกัดรูปสลิปของธนาคารใด)
              </p>
            </div>

            <button type="submit" class="btn btn-primary" style="width: 100%; margin-top: 1.5rem;">
              ✅ ฉันโอนเงินแล้วและยืนยันรับสิทธิ์
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>

  <!-- Section 3: History Logs for this User -->
  <div class="card">
    <h3 style="color: var(--text); margin-bottom: 1rem; border-bottom: 2px solid #f1f5f9; padding-bottom: 0.5rem; display: flex; align-items: center; gap: 0.5rem;">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"></path><path d="M12 6v6l4 2"></path></svg>
      ประวัติการทำรายการโอนสิทธิ์ของคุณ (Transaction History)
    </h3>

    <% if (history.length === 0) { %>
      <p style="color: var(--text-light); text-align: center; padding: 2rem 0; font-size: 0.95rem;">
        ไม่มีประวัติรายการโอนสิทธิ์สำเร็จ
      </p>
    <% } else { %>
      <div class="table-responsive">
        <table>
          <thead>
            <tr>
              <th>ประเภท</th>
              <th>คู่ค้า</th>
              <th>ไอเทม (Items)</th>
              <th>ยอดเงิน</th>
              <th>เวลาที่สำเร็จ</th>
              <th>สลิปหลักฐาน</th>
            </tr>
          </thead>
          <tbody>
            <% history.forEach(log => { %>
              <% const isSent = log.sender_id === user.discord_user_id; %>
              <tr>
                <td>
                  <span class="badge <%= isSent ? 'badge-danger' : 'badge-success' %>" style="background-color: <%= isSent ? '#fef2f2' : '#ecfdf5' %>; color: <%= isSent ? '#991b1b' : '#065f46' %>">
                    <%= isSent ? '📤 โอนสิทธิ์' : '📥 รับสิทธิ์' %>
                  </span>
                </td>
                <td style="font-weight: 600;"><%= isSent ? log.recipient_name : log.sender_name %></td>
                <td style="font-size: 0.9rem; line-height: 1.4;"><%- formatLogItemNames(log.item_names) %></td>
                <td style="font-weight: 700; color: var(--primary);"><%= log.amount.toLocaleString() %> บาท</td>
                <td style="font-size: 0.85rem; color: var(--text-light);">
                  <%= formatDate(log.completed_at) %> <%= formatTime(log.completed_at) %>
                </td>
                <td>
                  <% if (log.slip_url) { %>
                    <a href="<%= log.slip_url %>" target="_blank" class="btn btn-secondary" style="padding: 0.25rem 0.5rem; font-size: 0.75rem; font-weight: 500; display: inline-flex; width: auto; gap: 0.2rem;">
                      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
                      ดูสลิป
                    </a>
                  <% } else { %>
                    <span style="color: var(--text-light); font-size: 0.85rem;">ไม่มีหลักฐาน</span>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>
</div>

<script>
  let activeTransfer = null;

  function showClaimDetails(transfer) {
    activeTransfer = transfer;
    
    // Set form action url
    document.getElementById('claim-form').action = '/transfer/claim/' + transfer.id;



    // Group items by page name
    const grouped = {};
    (transfer.items || []).forEach(item => {
      if (!grouped[item.page_name]) {
        grouped[item.page_name] = [];
      }
      grouped[item.page_name].push(item);
    });

    // Populate modal-items-container
    const container = document.getElementById('modal-items-container');
    container.innerHTML = '';

    Object.keys(grouped).forEach(pageName => {
      const pageDiv = document.createElement('div');
      pageDiv.style.background = 'white';
      pageDiv.style.border = '1px solid #e2e8f0';
      pageDiv.style.borderRadius = '8px';
      pageDiv.style.padding = '0.5rem 0.75rem';
      pageDiv.style.display = 'flex';
      pageDiv.style.flexDirection = 'column';
      pageDiv.style.height = 'fit-content';

      // Page Header
      const header = document.createElement('h4');
      header.style.fontSize = '0.8rem';
      header.style.fontWeight = '700';
      header.style.color = 'var(--primary)';
      header.style.borderBottom = '1px solid #f1f5f9';
      header.style.paddingBottom = '0.3rem';
      header.style.marginTop = '0';
      header.style.marginBottom = '0.5rem';
      header.style.display = 'flex';
      header.style.justifyContent = 'space-between';
      header.style.alignItems = 'center';
      
      header.innerHTML = `
        <span style="display: flex; align-items: center; gap: 0.25rem;">
          <input type="checkbox" checked style="width: auto; height: 12px; cursor: pointer; margin: 0;" onchange="toggleSelectModalPage(this)">
          <span style="font-size: 0.75rem;">📄 ${pageName}</span>
        </span>
      `;
      pageDiv.appendChild(header);

      // Items container
      const itemsDiv = document.createElement('div');
      itemsDiv.style.display = 'flex';
      itemsDiv.style.flexDirection = 'column';
      itemsDiv.style.gap = '0.35rem';

      grouped[pageName].forEach(item => {
        const label = document.createElement('label');
        label.style.display = 'flex';
        label.style.alignItems = 'center';
        label.style.gap = '0.3rem';
        label.style.border = '1px solid var(--primary)';
        label.style.padding = '0.4rem 0.6rem';
        label.style.borderRadius = '6px';
        label.style.cursor = 'pointer';
        label.style.transition = 'all 0.2s';
        label.style.marginBottom = '0';
        label.style.backgroundColor = '#eff6ff'; // checked by default
        label.style.whiteSpace = 'nowrap';

        const displayType = clientDisplayItemType(item.item_type);
        label.innerHTML = `
          <input type="checkbox" name="item_ids" value="${item.id}" checked style="width: auto; height: 14px; cursor: pointer; margin: 0;" onchange="updateModalCardStyle(this)">
          <span style="font-size: 0.75rem; font-weight: 700; color: #1e293b; line-height: 1.2;">${displayType} (#${item.position})</span>
        `;
        itemsDiv.appendChild(label);
      });
      pageDiv.appendChild(itemsDiv);
      container.appendChild(pageDiv);
    });

    // Show details based on transfer options
    // 1. Bank
    const bankSection = document.getElementById('details-bank');
    if (transfer.bank_name && transfer.bank_account_number) {
      bankSection.style.display = 'block';
      document.getElementById('details-bank-name').innerText = transfer.bank_name;
      document.getElementById('details-bank-acc').innerText = transfer.bank_account_number;
      document.getElementById('details-bank-holder').innerText = transfer.bank_account_name || '-';
    } else {
      bankSection.style.display = 'none';
    }

    // 2. Personal QR Code
    const qrSection = document.getElementById('details-qr');
    if (transfer.payment_qr_url) {
      qrSection.style.display = 'block';
      document.getElementById('details-qr-img').src = transfer.payment_qr_url;
      document.getElementById('details-qr-download').href = transfer.payment_qr_url;
    } else {
      qrSection.style.display = 'none';
    }

    // 3. PromptPay ID
    const ppSection = document.getElementById('details-promptpay');
    if (transfer.promptpay_id) {
      ppSection.style.display = 'block';
      document.getElementById('details-pp-id').innerText = transfer.promptpay_id;
      document.getElementById('details-pp-name').innerText = transfer.promptpay_name || 'ไม่ได้ระบุ';
      
      // Clear PromptPay canvas initially
      const canvas = document.getElementById('promptpay-qr-canvas');
      const ctx = canvas.getContext('2d');
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      
      // Draw placeholder
      QRCode.toCanvas(canvas, 'https://github.com/dtinth/promptpay-qr', { width: 180, margin: 2 });
    } else {
      ppSection.style.display = 'none';
    }
    
    // Recalculate total immediately on open using the loaded localStorage prices
    recalculateTotalFromPrices();

    // Show main details card modal
    document.getElementById('claim-modal-overlay').style.display = 'flex';
    document.body.style.overflow = 'hidden'; // Disable scroll
  }

  function closeClaimDetails() {
    document.getElementById('claim-modal-overlay').style.display = 'none';
    document.body.style.overflow = 'auto'; // Re-enable scroll
    activeTransfer = null;
  }

  // Checkbox helpers
  function clientDisplayItemType(type) {
    if (type === 'Album') return '📒 Album';
    if (type === 'Illution Box') return '🧩 Box';
    if (type === 'Feather') return '🪶 Feather';
    if (type === 'Card') return '🎴 Card';
    if (type === 'Book') return '📖 Book';
    if (type === 'Light-Dark') return '🤍 Light-Dark';
    if (type === 'Time-Space') return '❤️ Time-Space';
    return type;
  }

  function selectAllModalItems(checked) {
    document.querySelectorAll('#modal-items-container input[name="item_ids"]').forEach(cb => {
      cb.checked = checked;
      updateModalCardStyle(cb, false); // pass false to avoid redundant calls
    });
    document.querySelectorAll('#modal-items-container input[type="checkbox"]:not([name="item_ids"])').forEach(cb => {
      cb.checked = checked;
    });
    recalculateTotalFromPrices();
  }

  function toggleSelectModalPage(pageCheckbox) {
    const pageCard = pageCheckbox.closest('div');
    const itemCheckboxes = pageCard.querySelectorAll('input[name="item_ids"]');
    itemCheckboxes.forEach(cb => {
      cb.checked = pageCheckbox.checked;
      updateModalCardStyle(cb, false); // pass false to avoid redundant calls
    });
    recalculateTotalFromPrices();
  }

  function updateModalCardStyle(cb, triggerRecalc = true) {
    const card = cb.closest('label');
    if (cb.checked) {
      card.style.backgroundColor = '#eff6ff'; // Light blue
      card.style.borderColor = 'var(--primary)';
    } else {
      card.style.backgroundColor = 'transparent';
      card.style.borderColor = '#e2e8f0';
    }
    if (triggerRecalc) {
      recalculateTotalFromPrices();
    }
  }

  // Listener to generate PromptPay QR when amount changes
  const amountInput = document.getElementById('amount');
  amountInput.addEventListener('input', function() {
    if (!activeTransfer || !activeTransfer.promptpay_id) return;
    
    const value = this.value;
    const canvas = document.getElementById('promptpay-qr-canvas');
    
    if (value && parseFloat(value) > 0) {
      const payload = generatePromptPayPayload(activeTransfer.promptpay_id, value);
      QRCode.toCanvas(canvas, payload, { width: 180, margin: 2 }, function (error) {
        if (error) console.error('Failed to draw QR:', error);
      });
    } else {
      // placeholder
      QRCode.toCanvas(canvas, 'https://github.com/dtinth/promptpay-qr', { width: 180, margin: 2 });
    }
  });

  // PromptPay EMVCo Generator Functions
  function crc16(data) {
    let crc = 0xFFFF;
    for (let i = 0; i < data.length; i++) {
      let x = ((crc >> 8) ^ data.charCodeAt(i)) & 0xFF;
      x ^= x >> 4;
      crc = ((crc << 8) ^ (x << 12) ^ (x << 5) ^ x) & 0xFFFF;
    }
    return crc.toString(16).toUpperCase().padStart(4, '0');
  }

  function generatePromptPayPayload(target, amount) {
    let id = target.replace(/[^0-9]/g, '');
    let idField = '';
    
    if (id.length === 13) {
      idField = '0213' + id;
    } else {
      if (id.startsWith('0')) {
        id = '66' + id.slice(1);
      }
      let padded = id.padStart(13, '0');
      idField = '0113' + padded;
    }
    
    let merchantInfo = '0016A000000677010111' + idField;
    let payload = '00020101021229' + merchantInfo.length.toString().padStart(2, '0') + merchantInfo;
    payload += '5303764'; // THB Currency
    
    if (amount) {
      let amountStr = parseFloat(amount).toFixed(2);
      payload += '54' + amountStr.length.toString().padStart(2, '0') + amountStr;
    }
    
    payload += '5802TH';
    payload += '6304';
    payload += crc16(payload);
    return payload;
  }

  // Copy helper
  function copyToClipboard(elementId) {
    const text = document.getElementById(elementId).innerText;
    navigator.clipboard.writeText(text).then(() => {
      alert('คัดลอกเลขบัญชีสำเร็จ: ' + text);
    }).catch(err => {
      console.error('Failed to copy:', err);
    });
  }

  function downloadPromptPayQR() {
    const canvas = document.getElementById('promptpay-qr-canvas');
    if (!canvas) return;
    const link = document.createElement('a');
    link.download = `promptpay-qr-${activeTransfer ? activeTransfer.id : 'temp'}.png`;
    link.href = canvas.toDataURL('image/png');
    link.click();
  }

  function recalculateTotalFromPrices() {
    if (!activeTransfer) return;
    
    const priceMap = {};
    document.querySelectorAll('.price-input-dynamic').forEach(input => {
      const type = input.getAttribute('data-type');
      priceMap[type] = parseFloat(input.value) || 0;
    });

    let total = 0;
    const checkedCheckboxes = document.querySelectorAll('input[name="item_ids"]:checked');
    checkedCheckboxes.forEach(cb => {
      const itemId = parseInt(cb.value);
      const item = (activeTransfer.items || []).find(i => i.id === itemId);
      if (item) {
        total += priceMap[item.item_type] || 0;
      }
    });

    const amountInput = document.getElementById('amount');
    amountInput.value = total > 0 ? total.toFixed(2).replace(/\.00$/, '') : '';
    amountInput.dispatchEvent(new Event('input'));
  }

  function saveAndRecalculatePrices() {
    document.querySelectorAll('.price-input-dynamic').forEach(input => {
      const type = input.getAttribute('data-type');
      localStorage.setItem('rooc_price_' + type, input.value);
    });

    updateCardTotals();

    if (activeTransfer) {
      recalculateTotalFromPrices();
    }
  }

  function updateCardTotals() {
    const priceMap = {};
    document.querySelectorAll('.price-input-dynamic').forEach(input => {
      const type = input.getAttribute('data-type');
      priceMap[type] = parseFloat(input.value) || 0;
    });

    document.querySelectorAll('.card-total-price-box').forEach(box => {
      try {
        const items = JSON.parse(box.getAttribute('data-items') || '[]');
        let cardTotal = 0;
        items.forEach(item => {
          cardTotal += priceMap[item.item_type] || 0;
        });
        
        const valueSpan = box.querySelector('.card-total-price-value');
        if (valueSpan) {
          if (cardTotal > 0) {
            valueSpan.innerText = cardTotal.toFixed(2).replace(/\.00$/, '') + ' บาท';
            box.style.display = 'flex';
          } else {
            valueSpan.innerText = '- บาท';
            box.style.display = 'none';
          }
        }
      } catch (err) {
        console.error('Error parsing card items:', err);
      }
    });
  }

  // Load persisted price calculator inputs from localStorage on page load
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.price-input-dynamic').forEach(input => {
      const type = input.getAttribute('data-type');
      input.value = localStorage.getItem('rooc_price_' + type) || '';
    });
    updateCardTotals();
  });

  // Submit button loading state
  document.getElementById('claim-form').addEventListener('submit', function() {
    const btn = this.querySelector('button[type="submit"]');
    if (btn) {
      btn.disabled = true;
      btn.innerHTML = '⌛ กำลังส่งข้อมูลและเคลมสิทธิ์...';
    }
  });

  // Auto refresh inbox every 15 seconds in the background (silently without reloading page)
  setInterval(() => {
    const overlay = document.getElementById('claim-modal-overlay');
    const isModalOpen = overlay && overlay.style.display !== 'none';
    
    // Only refresh if modal is not open to avoid disrupting active claims
    if (!isModalOpen) {
      fetch(window.location.href)
        .then(res => res.text())
        .then(html => {
          const parser = new DOMParser();
          const doc = parser.parseFromString(html, 'text/html');
          const newInbox = doc.getElementById('pending-inbox-container');
          const oldInbox = document.getElementById('pending-inbox-container');
          if (newInbox && oldInbox) {
            oldInbox.innerHTML = newInbox.innerHTML;
            updateCardTotals();
          }
        })
        .catch(err => console.error('Silent refresh failed:', err));
    }
  }, 15000); // 15 seconds
</script>
