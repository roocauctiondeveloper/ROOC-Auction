<style>
  .pages-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    max-height: 400px;
    overflow-y: auto;
    background: #f8fafc;
    padding: 1rem;
    border-radius: 8px;
    border: 1px solid #e2e8f0;
  }
  @media (max-width: 1400px) {
    .pages-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 768px) {
    .pages-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<div class="flex-desktop" style="display: flex; gap: 2rem;">
  <!-- Left Side: Form -->
  <div style="flex: 1.5;">
    <div class="card">
      <h2 style="color: var(--primary); margin-bottom: 0.5rem; display: flex; align-items: center; gap: 0.5rem;">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="8.5" cy="7" r="4"></circle><line x1="20" y1="8" x2="20" y2="14"></line><line x1="23" y1="11" x2="17" y2="11"></line></svg>
        ส่งข้อเสนอโอนสิทธิ์จองไอเทม
      </h2>
      <p style="color: var(--text-light); margin-bottom: 1.5rem; font-size: 0.95rem;">
        เลือกไอเทมที่คุณได้สิทธิ์จองไว้ในรอบปัจจุบัน และระบุผู้รับปลายทางพร้อมรายละเอียดชำระเงิน
      </p>

      <form action="/transfer/send" method="POST" enctype="multipart/form-data">
        <!-- 1. Select Item (Checkbox List with Toolbar) -->
        <div class="form-group">
          <label style="font-weight: 700; margin-bottom: 0.5rem; display: block;">1. เลือกไอเทมของคุณที่ต้องการโอน (เลือกได้หลายชิ้น):</label>
          <% if (myReservedItems.length === 0) { %>
            <div style="padding: 1rem; border: 1px dashed #cbd5e1; border-radius: 8px; background: #f8fafc; text-align: center; color: var(--text-light); font-size: 0.9rem;">
              -- คุณไม่มีสิทธิ์จองไอเทมว่างในรอบนี้ หรือไอเทมทั้งหมดกำลังอยู่ในคิวเสนอโอน --
            </div>
            <p style="color: var(--danger); font-size: 0.85rem; margin-top: 0.5rem;">
              *หมายเหตุ: คุณต้องทำการจองไอเทมจากบอร์ด Discord หรือให้แอดมินมอบหมายสิทธิ์ให้คุณก่อน จึงจะทำรายการโอนสิทธิ์ได้
            </p>
          <% } else { %>
            <!-- Toolbar for selecting categories client-side -->
            <div style="display: flex; gap: 0.4rem; flex-wrap: wrap; margin-bottom: 0.75rem;">
              <button type="button" class="btn btn-secondary" style="padding: 0.25rem 0.5rem; font-size: 0.75rem; border: 1px solid #cbd5e1; color: #475569;" onclick="selectAllItems(true)">☑️ เลือกทั้งหมด</button>
              <button type="button" class="btn btn-secondary" style="padding: 0.25rem 0.5rem; font-size: 0.75rem; border: 1px solid #cbd5e1; color: #475569;" onclick="selectAllItems(false)">❌ ล้างทั้งหมด</button>
              
              <% 
                const predefinedOrder = ['Album', 'Light-Dark', 'Time-Space'];
                const uniqueCategories = [...new Set(myReservedItems.map(i => i.item_type))];
                uniqueCategories.sort((a, b) => {
                  const idxA = predefinedOrder.indexOf(a);
                  const idxB = predefinedOrder.indexOf(b);
                  const valA = idxA === -1 ? 999 : idxA;
                  const valB = idxB === -1 ? 999 : idxB;
                  return valA - valB;
                });
                uniqueCategories.forEach(cat => {
              %>
                <button type="button" class="btn btn-secondary" style="padding: 0.25rem 0.5rem; font-size: 0.75rem; border: 1px solid #cbd5e1; color: #475569;" onclick="selectByCategory('<%= cat %>')"><%= displayItemType(cat) %></button>
              <% }) %>
            </div>

            <!-- Grouped by Page name -->
            <%
              const groupedItems = {};
              myReservedItems.forEach(item => {
                if (!groupedItems[item.page_name]) {
                  groupedItems[item.page_name] = [];
                }
                groupedItems[item.page_name].push(item);
              });
            %>
            <div class="pages-grid">
              <% Object.keys(groupedItems).forEach(pageName => { %>
                <div style="background: white; border: 1px solid #e2e8f0; border-radius: 8px; padding: 0.75rem 1rem; box-shadow: var(--shadow-sm); display: flex; flex-direction: column; height: fit-content;">
                  <h4 style="font-size: 0.85rem; font-weight: 700; color: var(--primary); border-bottom: 2px solid #f1f5f9; padding-bottom: 0.4rem; margin-top: 0; margin-bottom: 0.6rem; display: flex; justify-content: space-between; align-items: center;">
                    <span style="display: flex; align-items: center; gap: 0.3rem;">
                      <input type="checkbox" style="width: auto; height: 14px; cursor: pointer; margin: 0;" onchange="toggleSelectPage(this)">
                      <span>📄 <%= pageName %></span>
                    </span>
                    <span style="font-size: 0.75rem; color: var(--text-light); font-weight: 500;">มี <%= groupedItems[pageName].length %> ชิ้น</span>
                  </h4>
                  <div style="display: flex; flex-direction: column; gap: 0.4rem;">
                    <% groupedItems[pageName].forEach(item => { %>
                      <label class="item-card" style="display: flex; align-items: center; gap: 0.4rem; border: 1px solid #e2e8f0; padding: 0.5rem 0.75rem; border-radius: 6px; cursor: pointer; transition: all 0.2s; margin-bottom: 0; position: relative; white-space: nowrap;" onmouseover="this.style.borderColor='var(--primary)'" onmouseout="if(!this.querySelector('input').checked) this.style.borderColor='#e2e8f0'">
                        <input type="checkbox" name="item_ids" value="<%= item.item_id %>" data-category="<%= item.item_type %>" style="width: auto; height: 16px; cursor: pointer; margin: 0;" onchange="updateCardStyle(this)">
                        <span style="font-size: 0.85rem; font-weight: 700; color: #1e293b; line-height: 1.2;"><%= displayItemType(item.item_type) %> (#<%= item.position %>)</span>
                      </label>
                    <% }) %>
                  </div>
                </div>
              <% }) %>
            </div>
            <p style="color: var(--text-light); font-size: 0.85rem; margin-top: 0.5rem;">
              *ติ๊กถูกหน้าของที่ต้องการเสนอโอน สามารถเลือกหลายชิ้นเพื่อส่งพร้อมกันในบิลเดียวได้
            </p>
          <% } %>
        </div>

        <!-- 2. Select Recipient using native datalist search box -->
        <div class="form-group">
          <label for="recipient_id">2. ระบุผู้รับปลายทาง (พิมพ์ชื่อ หรือ Discord ID เพื่อค้นหา):</label>
          <input type="text" name="recipient_id" id="recipient_id" list="recipient-list" required placeholder="พิมพ์ค้นหาชื่อ หรือพิมพ์ Discord ID ที่ต้องการโอนสิทธิ์ให้..." style="width: 100%;">
          <datalist id="recipient-list">
            <% members.forEach(m => { %>
              <option value="<%= m.name %> (<%= m.id %>)"></option>
            <% }) %>
          </datalist>
        </div>

        <!-- 3. Payment details -->
        <div style="border-top: 1px solid #e2e8f0; margin-top: 2rem; padding-top: 1.5rem;">
          <h3 style="font-size: 1.1rem; margin-bottom: 1rem; color: #0f172a;">3. ระบุช่องทางการรับเงิน (กรอกอย่างน้อย 1 ช่องทาง):</h3>
          
          <!-- Tabbed buttons for payment methods -->
          <div style="display: flex; gap: 0.5rem; margin-bottom: 1.5rem; background: #f1f5f9; padding: 0.3rem; border-radius: 8px;">
            <button type="button" class="btn" id="tab-bank" style="flex: 1; font-size: 0.85rem; padding: 0.5rem;" onclick="switchPaymentTab('bank')">🏛️ บัญชีธนาคาร</button>
            <button type="button" class="btn" id="tab-promptpay" style="flex: 1; font-size: 0.85rem; padding: 0.5rem;" onclick="switchPaymentTab('promptpay')">💳 PromptPay</button>
            <button type="button" class="btn" id="tab-qr" style="flex: 1; font-size: 0.85rem; padding: 0.5rem;" onclick="switchPaymentTab('qr')">🖼️ รูปภาพ QR</button>
          </div>

          <!-- Tab Bank -->
          <div id="payment-bank" class="payment-tab-content">
            <div class="form-group">
              <label for="bank_name">ชื่อธนาคาร:</label>
              <select name="bank_name" id="bank_name">
                <option value="">-- เลือกธนาคาร --</option>
                <% 
                  const banks = [
                    "ธนาคารกสิกรไทย (KBank)",
                    "ธนาคารไทยพาณิชย์ (SCB)",
                    "ธนาคารกรุงเทพ (BBL)",
                    "ธนาคารกรุงไทย (KTB)",
                    "ธนาคารกรุงศรีอยุธยา (BAY)",
                    "ธนาคารทหารไทยธนชาต (TTB)",
                    "ธนาคารออมสิน (GSB)"
                  ];
                  banks.forEach(bank => {
                %>
                  <option value="<%= bank %>" <%= lastPayment.bank_name === bank ? 'selected' : '' %>><%= bank %></option>
                <% }) %>
              </select>
            </div>
            <div class="form-group">
              <label for="bank_account_number">เลขบัญชีธนาคาร:</label>
              <input type="text" name="bank_account_number" id="bank_account_number" placeholder="เช่น 123-4-56789-0" value="<%= lastPayment.bank_account_number || '' %>">
            </div>
            <div class="form-group">
              <label for="bank_account_name">ชื่อเจ้าของบัญชี:</label>
              <input type="text" name="bank_account_name" id="bank_account_name" placeholder="ชื่อ-นามสกุล" value="<%= lastPayment.bank_account_name || '' %>">
            </div>
          </div>

          <!-- Tab PromptPay -->
          <div id="payment-promptpay" class="payment-tab-content" style="display: none;">
            <div class="form-group">
              <label for="promptpay_id">เบอร์ PromptPay (หรือเลขบัตรประชาชน):</label>
              <input type="text" name="promptpay_id" id="promptpay_id" placeholder="เช่น 0812345678" value="<%= lastPayment.promptpay_id || '' %>">
            </div>
            <div class="form-group">
              <label for="promptpay_name">ชื่อบัญชี PromptPay (สำหรับให้คนซื้อ Recheck):</label>
              <input type="text" name="promptpay_name" id="promptpay_name" placeholder="ชื่อจริงที่ลงทะเบียนไว้" value="<%= lastPayment.promptpay_name || '' %>">
            </div>
          </div>

          <!-- Tab QR Image -->
          <div id="payment-qr" class="payment-tab-content" style="display: none;">
            <div class="form-group">
              <label for="payment_qr">อัปโหลดไฟล์ภาพ QR Code รับเงิน:</label>
              <input type="file" name="payment_qr" id="payment_qr" accept="image/*">
              <% if (lastPayment.payment_qr_url) { %>
                <p style="color: #15803d; font-size: 0.85rem; margin-top: 0.4rem; font-weight: 600;">
                  ✔️ มีรูปภาพ QR Code เดิมที่เคยอัปโหลดไว้แล้ว (หากไม่ประสงค์จะเปลี่ยน ไม่จำเป็นต้องเลือกไฟล์ใหม่)
                </p>
              <% } %>
              <p style="color: var(--text-light); font-size: 0.8rem; margin-top: 0.3rem;">
                *รองรับไฟล์รูปภาพเท่านั้น เช่น JPG, PNG ไม่เกิน 5MB
              </p>
            </div>
          </div>
        </div>

        <button type="submit" class="btn btn-primary" style="width: 100%; margin-top: 1.5rem;" <%= myReservedItems.length === 0 ? 'disabled' : '' %>>
          🚀 ส่งข้อเสนอโอนสิทธิ์
        </button>
      </form>
    </div>
  </div>

  <!-- Right Side: Pending Sent & History -->
  <div style="flex: 1;">
    <div class="card" style="padding: 1.5rem;">
      <h3 style="color: var(--text); margin-bottom: 1rem; border-bottom: 2px solid #f1f5f9; padding-bottom: 0.5rem; display: flex; align-items: center; gap: 0.5rem;">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
        รายการเสนอโอนที่อยู่ระหว่างรอรับ
      </h3>
      
      <% if (pendingSent.length === 0) { %>
        <p style="color: var(--text-light); text-align: center; padding: 2rem 0; font-size: 0.95rem;">
          ไม่มีรายการโอนสิทธิ์ค้างรอชำระเงิน
        </p>
      <% } else { %>
        <div style="display: flex; flex-direction: column; gap: 1rem;">
          <% pendingSent.forEach(transfer => { %>
            <div style="border: 1px solid #e2e8f0; border-radius: 8px; padding: 1rem; background: #fafafa; position: relative;">
              <div style="font-weight: 600; font-size: 0.95rem; color: #0f172a; margin-bottom: 0.3rem;">
                [<%= transfer.page_name %>] <%= displayItemType(transfer.item_type) %>
              </div>
              <div style="font-size: 0.85rem; color: var(--text-light); margin-bottom: 0.75rem;">
                ส่งให้: <strong><%= transfer.recipient_name %></strong><br>
                สร้างเมื่อ: <%= formatDate(transfer.created_at) %> <%= formatTime(transfer.created_at) %>
              </div>
              
              <form action="/transfer/cancel/<%= transfer.id %>" method="POST" style="margin: 0;" onsubmit="return confirm('ยืนยันยกเลิกคำขอเสนอโอนนี้หรือไม่?')">
                <button type="submit" class="btn btn-danger" style="padding: 0.4rem 0.8rem; font-size: 0.8rem; width: auto; font-weight: 500;">
                  ❌ ยกเลิกข้อเสนอ
                </button>
              </form>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>
  </div>
</div>

<!-- Section 3: History Logs for this User as Sender -->
<div class="card" style="margin-top: 2rem;">
  <h3 style="color: var(--text); margin-bottom: 1rem; border-bottom: 2px solid #f1f5f9; padding-bottom: 0.5rem; display: flex; align-items: center; gap: 0.5rem;">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"></path><path d="M12 6v6l4 2"></path></svg>
    ประวัติการเสนอโอนสิทธิ์ที่สำเร็จของคุณ (Sales History)
  </h3>

  <% if (history.length === 0) { %>
    <p style="color: var(--text-light); text-align: center; padding: 2rem 0; font-size: 0.95rem;">
      ไม่มีประวัติรายการเสนอโอนสิทธิ์สำเร็จ
    </p>
  <% } else { %>
    <div class="table-responsive">
      <table>
        <thead>
          <tr>
            <th>ประเภท</th>
            <th>ผู้รับโอน (Recipient)</th>
            <th>ไอเทม (Items)</th>
            <th>ยอดเงิน</th>
            <th>เวลาที่สำเร็จ</th>
            <th>สลิปโอนเงิน</th>
          </tr>
        </thead>
        <tbody>
          <% history.forEach(log => { %>
            <tr>
              <td>
                <span class="badge badge-blue">📤 ส่งออก</span>
              </td>
              <td style="font-weight: 600; color: #0f172a;">
                <%= log.recipient_name %>
              </td>
              <td>
                <%- formatLogItemNames(log.item_names) %>
              </td>
              <td style="font-weight: 700; color: var(--primary);">
                <%= parseFloat(log.amount).toLocaleString() %> บาท
              </td>
              <td style="font-size: 0.85rem; color: var(--text-light);">
                <%= formatDate(log.completed_at) %> <%= formatTime(log.completed_at) %>
              </td>
              <td>
                <% if (log.slip_url) { %>
                  <a href="<%= log.slip_url %>" target="_blank" class="btn btn-secondary" style="padding: 0.25rem 0.5rem; font-size: 0.75rem; display: inline-flex;">🖼️ ดูสลิป</a>
                <% } else { %>
                  -
                <% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>

<script>
  // Native search datalist is handled natively by the browser.

  // Switch between Payment tabs
  function switchPaymentTab(tabName) {
    // Hide all
    document.querySelectorAll('.payment-tab-content').forEach(el => el.style.display = 'none');
    document.querySelectorAll('[id^="tab-"]').forEach(btn => {
      btn.style.backgroundColor = 'transparent';
      btn.style.color = '#475569';
    });

    // Show selected
    document.getElementById('payment-' + tabName).style.display = 'block';
    const activeBtn = document.getElementById('tab-' + tabName);
    activeBtn.style.backgroundColor = 'var(--primary)';
    activeBtn.style.color = 'white';
  }

  // Initialize first tab
  document.addEventListener('DOMContentLoaded', () => {
    switchPaymentTab('bank');
  });

  // Checkbox selecting functions
  function selectAllItems(checked) {
    document.querySelectorAll('input[name="item_ids"]').forEach(cb => {
      cb.checked = checked;
      updateCardStyle(cb);
    });
  }

  function selectByCategory(category) {
    document.querySelectorAll('input[name="item_ids"]').forEach(cb => {
      cb.checked = (cb.getAttribute('data-category') === category);
      updateCardStyle(cb);
    });
  }

  function updateCardStyle(cb) {
    const card = cb.closest('label');
    if (cb.checked) {
      card.style.backgroundColor = '#eff6ff'; // Light blue
      card.style.borderColor = 'var(--primary)';
    } else {
      card.style.backgroundColor = 'transparent';
      card.style.borderColor = '#e2e8f0';
    }
  }

  function toggleSelectPage(pageCheckbox) {
    const pageCard = pageCheckbox.closest('div');
    const itemCheckboxes = pageCard.querySelectorAll('input[name="item_ids"]');
    itemCheckboxes.forEach(cb => {
      cb.checked = pageCheckbox.checked;
      updateCardStyle(cb);
    });
  }

  // Submit button loading state
  document.querySelector('form').addEventListener('submit', function() {
    const btn = this.querySelector('button[type="submit"]');
    if (btn) {
      btn.disabled = true;
      btn.innerHTML = '⌛ กำลังส่งข้อเสนอโอนสิทธิ์...';
    }
  });

  // Auto refresh page every 15 seconds to fetch new items/offers, but only if user is idle (not selecting/typing)
  setInterval(() => {
    // Check if any checkboxes are checked
    const checkedItems = document.querySelectorAll('input[name="item_ids"]:checked').length;
    // Check if recipient input has value or focus
    const recipientInput = document.getElementById('recipient_id');
    const isRecipientActive = recipientInput && (recipientInput.value.trim() !== '' || document.activeElement === recipientInput);
    // Check if bank/payment fields have values or focus
    const bankAcc = document.getElementById('bank_account_number');
    const isBankActive = bankAcc && (bankAcc.value.trim() !== '' || document.activeElement === bankAcc);
    const ppId = document.getElementById('promptpay_id');
    const isPPActive = ppId && (ppId.value.trim() !== '' || document.activeElement === ppId);

    if (checkedItems === 0 && !isRecipientActive && !isBankActive && !isPPActive) {
      window.location.reload();
    }
  }, 15000); // 15 seconds
</script>
